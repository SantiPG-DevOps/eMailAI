/* =========================
   eMailAI - MODO OSCURO
   ========================= */

.root {
    -fx-background-color: #0F172A;
    -fx-base: #0F172A;
    -fx-text-fill: #F1F5F9;
    -fx-font-family: "Segoe UI", "Roboto", "Sans-Serif";
    -fx-selection-bar:      #38BDF8;
    -fx-selection-bar-text: #0F172A;
}

.main-background {
    -fx-background-color: #0F172A;
}

.sidebar {
    -fx-background-color: #1E293B;
}

.main-app-sidebar {
    -fx-background-color: #0B1220;
    -fx-border-color: transparent #1E293B transparent transparent;
    -fx-border-width: 0 1 0 0;
}

.main-sidebar-brand {
    -fx-font-size: 16px;
    -fx-font-weight: bold;
    -fx-text-fill: #F8FAFC;
}

.main-nav-heading { -fx-text-fill: #94A3B8; }

.main-nav-submenu-heading {
    -fx-text-fill: #64748B;
    -fx-padding: 4 0 2 4;
}

.main-nav-submenu { -fx-background-color: transparent; }

.toggle-button.main-nav-primary {
    -fx-background-radius: 8;
    -fx-padding: 10 12;
    -fx-font-size: 13px;
    -fx-max-width: Infinity;
    -fx-content-display: LEFT;
    -fx-background-color: transparent;
    -fx-text-fill: #E2E8F0;
    -fx-border-color: transparent;
    -fx-border-width: 0;
}

.toggle-button.main-nav-primary:hover { -fx-background-color: #1E293B; }

.toggle-button.main-nav-primary:selected {
    -fx-background-color: #38BDF8;
    -fx-text-fill: #0F172A;
}

.main-nav-folder-list {
    -fx-background-color: transparent;
    -fx-border-width: 0;
    -fx-padding: 0;
}

.main-nav-folder-list .list-cell {
    -fx-background-insets: 2 4;
    -fx-padding: 0 8 0 8;
    -fx-background-radius: 6;
    -fx-text-fill: #CBD5E1;
    -fx-font-size: 12px;
    -fx-background-color: transparent;
}

.main-nav-folder-list .list-cell:filled:hover { -fx-background-color: #1E293B; }

.main-nav-folder-list .list-cell:filled:selected,
.main-nav-folder-list .list-cell:filled:selected:focused {
    -fx-background-color: #334155;
    -fx-text-fill: #F8FAFC;
}

.card {
    -fx-background-color: #1E293B;
    -fx-background-radius: 12;
    -fx-border-radius: 12;
    -fx-border-color: #334155;
    -fx-border-width: 1;
}

.config-root { -fx-background-color: #0F172A; }

.config-header-wrap {
    -fx-background-color: #0B1220;
    -fx-border-color: #334155;
}

.config-footer-wrap { -fx-background-color: #0B1220; }

.config-screen-title  { -fx-text-fill: #F8FAFC; }
.config-page-heading  { -fx-text-fill: #F1F5F9; }
.config-section-kicker { -fx-text-fill: #E2E8F0; }
.config-field-label   { -fx-text-fill: #CBD5E1; }
.config-nav-heading   { -fx-text-fill: #94A3B8; }

.config-header-accent {
    -fx-background-color: #38BDF8;
    -fx-background-radius: 3;
}

.config-nav-pane {
    -fx-background-color: #0B1220;
    -fx-border-color: transparent #1E293B transparent transparent;
    -fx-border-width: 0 1 0 0;
}

.config-content-stack { -fx-background-color: #0F172A; }

.config-section-box {
    -fx-background-color: #1E293B;
    -fx-border-color: #334155 #334155 #334155 #38BDF8;
    -fx-border-width: 1 1 1 4;
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 16, 0, 0, 4);
}

.config-nav-list { -fx-background-color: transparent; }

.config-nav-list .list-cell {
    -fx-background-color: transparent;
    -fx-text-fill: #E2E8F0;
}

.config-nav-list .list-cell:filled:hover { -fx-background-color: #1E293B; }

.config-nav-list .list-cell:filled:selected,
.config-nav-list .list-cell:filled:selected:focused {
    -fx-background-color: #38BDF8;
    -fx-text-fill: #0F172A;
}

.config-split > .split-pane-divider { -fx-background-color: #334155; }

.elevated {
    -fx-background-color: #334155;
    -fx-background-radius: 16;
}

.top-bar { -fx-background-color: #1E293B; }

.ia-panel {
    -fx-background-color: #1E293B;
    -fx-background-radius: 10;
    -fx-padding: 8 10 8 10;
}

.label         { -fx-text-fill: #F1F5F9; }
.section-label { -fx-text-fill: #F1F5F9; -fx-font-weight: bold; }

.label-secondary {
    -fx-text-fill: #94A3B8;
    -fx-font-size: 12px;
}

.message-subject {
    -fx-text-fill: #38BDF8;
    -fx-font-size: 16px;
    -fx-font-weight: bold;
    -fx-max-width: 400;
}

.status-label {
    -fx-text-fill: #22D3EE;
    -fx-font-size: 12px;
}

.text-field {
    -fx-background-color: #0F172A;
    -fx-control-inner-background: #0F172A;
    -fx-text-fill: #F1F5F9;
    -fx-prompt-text-fill: #94A3B8;
    -fx-border-color: #334155;
    -fx-border-radius: 8;
    -fx-background-radius: 8;
}

.text-field:focused { -fx-border-color: #22D3EE; }

.text-area {
    -fx-control-inner-background: #0F172A;
    -fx-background-color: #1E293B;
    -fx-text-fill: #F1F5F9;
    -fx-border-color: #334155;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
}

.list-view {
    -fx-background-color: #0F172A;
    -fx-control-inner-background: #1E293B;
    -fx-text-fill: #F1F5F9;
    -fx-padding: 4;
}

.list-cell.message-card {
    -fx-background-color: #1E293B;
    -fx-text-fill: #F1F5F9;
    -fx-padding: 6 10 6 10;
}

.list-cell:empty { -fx-background-color: transparent; }

.list-cell.message-card:selected {
    -fx-background-color: #38BDF8;
    -fx-text-fill: #0F172A;
}

.list-cell.message-card.footer {
    -fx-background-color: #334155;
    -fx-text-fill: #F1F5F9;
}

.button {
    -fx-background-color: #22D3EE;
    -fx-text-fill: #0F172A;
    -fx-font-weight: bold;
    -fx-background-radius: 20;
    -fx-border-radius: 20;
    -fx-border-color: transparent;
}

.button:hover { -fx-background-color: #67E8F9; }

.action-button {
    -fx-background-color: #1E293B;
    -fx-text-fill: #F1F5F9;
    -fx-background-radius: 16;
    -fx-border-radius: 16;
    -fx-border-color: #22D3EE;
    -fx-border-width: 1;
    -fx-pref-height: 28;
    -fx-min-height: 28;
    -fx-max-height: 28;
    -fx-pref-width: 70;
    -fx-min-width: 70;
    -fx-max-width: 70;
    -fx-font-size: 11px;
    -fx-padding: 2 8 2 8;
}

.action-button:hover { -fx-background-color: #334155; }

.chip {
    -fx-background-color: #22D3EE;
    -fx-text-fill: #0F172A;
    -fx-background-radius: 20;
    -fx-border-radius: 20;
    -fx-font-size: 11px;
    -fx-padding: 4 12 4 12;
    -fx-wrap-text: true;
    -fx-pref-height: 30;
    -fx-min-width: 120;
}

.chip:hover { -fx-background-color: #67E8F9; }

.split-pane           { -fx-background-color: transparent; }
.split-pane-divider   { -fx-background-color: #0F172A; }

.scroll-bar:vertical,
.scroll-bar:horizontal { -fx-background-color: transparent; }

.scroll-bar .thumb {
    -fx-background-color: #334155;
    -fx-background-radius: 5;
}

.scroll-bar .thumb:hover { -fx-background-color: #38BDF8; }

.tab-pane { -fx-background-color: #0F172A; }

.tab {
    -fx-background-color: #1E293B;
    -fx-text-base-color: #F1F5F9;
}

.tab:selected {
    -fx-background-color: #38BDF8;
    -fx-text-base-color: #0F172A;
}

.glow-ia {
    -fx-effect: dropshadow(gaussian, #00F0FF, 20, 0.5, 0, 0);
}

.accounts-scroll {
    -fx-background-color: transparent;
    -fx-border-color: transparent;
}

.accounts-scroll > .viewport { -fx-background-color: transparent; }

.account-card {
    -fx-background-color: #1E293B;
    -fx-border-color: #334155;
    -fx-cursor: hand;
}

.account-card-selected {
    -fx-border-color: #38BDF8;
    -fx-background-color: #0B1220;
}

.account-email {
    -fx-text-fill: #F1F5F9;
    -fx-font-weight: bold;
}

.account-server {
    -fx-text-fill: #94A3B8;
    -fx-font-size: 11px;
}

.theme-toggle {
    -fx-background-color: #1E293B;
    -fx-text-fill: #F1F5F9;
    -fx-border-color: #334155;
}

/* ── CALENDARIO OSCURO ── */
.cal-dia {
    -fx-background-color: #1E293B;
    -fx-border-color: #475569;
    -fx-border-width: 1;
}

.cal-dia:hover   { -fx-background-color: #273548; }
.cal-dia:pressed { -fx-background-color: #2d3d52; }

.cal-dia-hoy {
    -fx-border-color: #22D3EE;
    -fx-border-width: 2;
    -fx-background-color: #1a3a5c;
}
.cal-dia-hoy:hover,
.cal-dia-hoy:pressed { -fx-background-color: #1e4570; }

.cal-dia-seleccionado {
    -fx-background-color: #1e3d60;
    -fx-border-color: #22D3EE;
    -fx-border-width: 2;
}
.cal-dia-seleccionado:hover,
.cal-dia-seleccionado:pressed { -fx-background-color: #234875; }

.cal-dia-urgente-semana {
    -fx-border-color: #F87171;
    -fx-border-width: 2;
    -fx-background-color: #450A0A;
}
.cal-dia-urgente-semana:hover,
.cal-dia-urgente-semana:pressed { -fx-background-color: #5a1010; }

.cal-dia-proxima-semana {
    -fx-border-color: #FBBF24;
    -fx-border-width: 2;
    -fx-background-color: #422006;
}
.cal-dia-proxima-semana:hover,
.cal-dia-proxima-semana:pressed { -fx-background-color: #573008; }

.cal-dia-mas-tarde {
    -fx-border-color: #4ADE80;
    -fx-border-width: 2;
    -fx-background-color: #14532D;
}
.cal-dia-mas-tarde:hover,
.cal-dia-mas-tarde:pressed { -fx-background-color: #1a6b3a; }

.cal-dia-seleccionado.cal-dia-urgente-semana,
.cal-dia-seleccionado.cal-dia-proxima-semana,
.cal-dia-seleccionado.cal-dia-mas-tarde {
    -fx-border-color: #22D3EE;
    -fx-border-width: 3;
}

.cal-dia-numero { -fx-text-fill: #E2E8F0; }
.cal-evento-barra { -fx-background-color: #2a7fa0; }

.cal-evento-barra-seleccionado {
    -fx-background-color: #4da6d0;
    -fx-border-color: #7ec8e3;
    -fx-border-width: 1;
    -fx-border-radius: 3;
}

/* ── MENSAJES CLASIFICADOS OSCURO ── */

/* Base común para correos en la lista */
.list-cell.message-card,
.list-cell.message-card-pending,
.list-cell.message-card-legit,
.list-cell.message-card-risk,
.list-cell.message-card-spam {
    -fx-padding: 6 10 6 10;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-border-width: 0 0 0 4;
}

/* Pendiente / sin clasificar -> amarillo */
.list-cell.message-card-pending {
    -fx-background-color: #2b2412;
    -fx-text-fill: #fde68a;
    -fx-border-color: transparent transparent transparent #fbbf24;
}

.list-cell.message-card-pending:filled:hover {
    -fx-background-color: #3a3016;
}

.list-cell.message-card-pending:filled:selected,
.list-cell.message-card-pending:filled:selected:focused {
    -fx-background-color: #78350f;
    -fx-text-fill: #fff7d6;
    -fx-border-color: transparent transparent transparent #fcd34d;
}

/* Legítimo -> verde */
.list-cell.message-card-legit {
    -fx-background-color: #13281b;
    -fx-text-fill: #bbf7d0;
    -fx-border-color: transparent transparent transparent #22c55e;
}

.list-cell.message-card-legit:filled:hover {
    -fx-background-color: #173320;
}

.list-cell.message-card-legit:filled:selected,
.list-cell.message-card-legit:filled:selected:focused {
    -fx-background-color: #14532d;
    -fx-text-fill: #f0fdf4;
    -fx-border-color: transparent transparent transparent #4ade80;
}

/* Spam / riesgo -> rojo */
.list-cell.message-card-risk,
.list-cell.message-card-spam {
    -fx-background-color: #2d1619;
    -fx-text-fill: #fecaca;
    -fx-border-color: transparent transparent transparent #ef4444;
}

.list-cell.message-card-risk:filled:hover,
.list-cell.message-card-spam:filled:hover {
    -fx-background-color: #3a1b1f;
}

.list-cell.message-card-risk:filled:selected,
.list-cell.message-card-risk:filled:selected:focused,
.list-cell.message-card-spam:filled:selected,
.list-cell.message-card-spam:filled:selected:focused {
    -fx-background-color: #7f1d1d;
    -fx-text-fill: #fef2f2;
    -fx-border-color: transparent transparent transparent #f87171;
}

/* ── SIDEBAR SUBMENU OSCURO ── */
.sidebar-submenu-toggle {
    -fx-background-color: #0B1220;
    -fx-text-fill: #CBD5E1;
    -fx-border-color: #334155;
    -fx-border-width: 1;
    -fx-border-radius: 8;
}

.sidebar-submenu-toggle:selected {
    -fx-background-color: #334155;
    -fx-text-fill: #F8FAFC;
    -fx-border-color: #38BDF8;
}

/* ── CONTACTOS OSCURO ── */
.list-cell.contact-card-cell {
    -fx-background-color: transparent;
    -fx-text-fill: #F1F5F9;
    -fx-padding: 2 4 2 4;
}

.list-cell.contact-card-cell:filled:hover {
    -fx-background-color: #1E293B;
    -fx-background-radius: 8;
}

.list-cell.contact-card-cell:filled:selected,
.list-cell.contact-card-cell:filled:selected:focused,
.list-cell.contact-card-cell:filled:selected:hover,
.list-cell.contact-card-cell:filled:selected:focused:hover {
    -fx-background-color: #38BDF8;
    -fx-background-radius: 8;
}

.list-cell.contact-card-cell:filled:selected .contact-name,
.list-cell.contact-card-cell:filled:selected:focused .contact-name,
.list-cell.contact-card-cell:filled:selected .contact-email,
.list-cell.contact-card-cell:filled:selected:focused .contact-email,
.list-cell.contact-card-cell:filled:selected .contact-phone,
.list-cell.contact-card-cell:filled:selected:focused .contact-phone {
    -fx-text-fill: #0F172A;
}

.contact-name  { -fx-text-fill: #F1F5F9; -fx-font-weight: bold; }
.contact-email { -fx-text-fill: #94A3B8; -fx-font-size: 11px;   }
.contact-phone { -fx-text-fill: #F1F5F9; }

/* ── BOTONES CONFIG OSCURO ── */
.button.config-primary-btn {
    -fx-font-size: 13px;
    -fx-font-weight: bold;
    -fx-padding: 10 20 10 20;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-background-color: #38BDF8;
    -fx-text-fill: #0F172A;
    -fx-border-color: transparent;
}

.button.config-primary-btn:hover { -fx-background-color: #7DD3FC; }

.button.config-secondary-btn {
    -fx-font-size: 13px;
    -fx-padding: 10 16 10 16;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-background-color: #1E293B;
    -fx-text-fill: #F1F5F9;
    -fx-border-color: #475569;
    -fx-border-width: 1;
}

.button.config-secondary-btn:hover {
    -fx-border-color: #38BDF8;
    -fx-background-color: #334155;
}

/* ── PAGINACIÓN OSCURO ── */
.btn-pag {
    -fx-background-color: #1E293B;
    -fx-text-fill: #CBD5E1;
}

.btn-pag:hover {
    -fx-background-color: #38BDF8;
    -fx-text-fill: #0F172A;
}

.btn-pag:disabled {
    -fx-background-color: #0B1220;
    -fx-text-fill: #475569;
    -fx-opacity: 0.6;
}

.pag-indicator {
    -fx-background-color: #0B1220;
    -fx-border-color: #334155;
}

.pag-label { 
	-fx-text-fill: #CBD5E1;
}

/* ── Filtro HOY → rojo oscuro ── */
.task-filter-hoy {
    -fx-background-color: #c62828;
    -fx-text-fill: white;
}
.task-filter-hoy:hover {
    -fx-background-color: #b71c1c;
    -fx-text-fill: white;
}
.task-filter-hoy:selected {
    -fx-background-color: #ff5252;
    -fx-text-fill: white;
    -fx-font-weight: bold;
}

/* ── Filtro MAÑANA → naranja oscuro ── */
.task-filter-manana {
    -fx-background-color: #e65100;
    -fx-text-fill: white;
}
.task-filter-manana:hover {
    -fx-background-color: #bf360c;
    -fx-text-fill: white;
}
.task-filter-manana:selected {
    -fx-background-color: #ff6d00;
    -fx-text-fill: white;
    -fx-font-weight: bold;
}

/* ── Filtro SEMANA → amarillo oscuro ── */
.task-filter-semana {
    -fx-background-color: #f9a825;
    -fx-text-fill: #111;
}
.task-filter-semana:hover {
    -fx-background-color: #f57f17;
    -fx-text-fill: #111;
}
.task-filter-semana:selected {
    -fx-background-color: #ffca28;
    -fx-text-fill: #111;
    -fx-font-weight: bold;
}

/* ── Filtro MES → verde oscuro ── */
.task-filter-mes {
    -fx-background-color: #2e7d32;
    -fx-text-fill: white;
}
.task-filter-mes:hover {
    -fx-background-color: #1b5e20;
    -fx-text-fill: white;
}
.task-filter-mes:selected {
    -fx-background-color: #69f0ae;
    -fx-text-fill: #111;
    -fx-font-weight: bold;
}

/* ── Badges prioridad ── */
.task-priority-alta  { -fx-background-color: #ff5252; -fx-text-fill: white; }
.task-priority-media { -fx-background-color: #ffca28; -fx-text-fill: #111;  }
.task-priority-baja  { -fx-background-color: #69f0ae; -fx-text-fill: #111;  }

/* — Añadir en styles-dark.css — */
.chat-bubble-user { -fx-background-color: #01696f; -fx-text-fill: white; }
.chat-bubble-ia   { -fx-background-color: #201f1d; -fx-text-fill: #cdccca;
                    -fx-border-color: #393836; }
.chat-header      { -fx-background-color: #1c1b19; -fx-border-color: #393836; }
.chat-input-bar   { -fx-background-color: #1c1b19; -fx-border-color: #393836; }
.chat-model-label { -fx-text-fill: #797876; }
.chat-typing-label{ -fx-text-fill: #797876; }