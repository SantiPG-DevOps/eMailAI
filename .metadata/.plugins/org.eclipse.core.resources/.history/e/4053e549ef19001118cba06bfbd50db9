package com.emailAI.dao;

import com.emailAI.model.Mensaje;

import java.sql.*;
import java.util.ArrayList;
import java.util.List;

public class DAOMensajes {

    public DAOMensajes() throws SQLException {
        crearTablaSiNoExiste();
    }

    private void crearTablaSiNoExiste() throws SQLException {
        String sql = """
                CREATE TABLE IF NOT EXISTS mensajes (
                    id            INTEGER PRIMARY KEY AUTOINCREMENT,
                    cuenta_hash   TEXT NOT NULL,
                    uid_imap      TEXT NOT NULL,
                    remitente     TEXT NOT NULL,
                    asunto        TEXT NOT NULL,
                    cuerpo        TEXT,
                    fecha         TEXT,
                    categoria     TEXT,
                    prioridad     TEXT
                );
                """;

        String idx = """
                CREATE UNIQUE INDEX IF NOT EXISTS idx_mensajes_cuenta_uid
                ON mensajes(cuenta_hash, uid_imap);
                """;

        try (Connection conn = ConexionBD.getConnection();
             Statement st = conn.createStatement()) {
            st.execute(sql);
            st.execute(idx);
        }
    }

    // Obtener todos los mensajes de una cuenta (ordenados por fecha desc)
    public List<Mensaje> listarPorCuenta(String cuentaHash) throws SQLException {
        String sql = """
                SELECT remitente, asunto, cuerpo, fecha, categoria, prioridad, uid_imap
                FROM mensajes
                WHERE cuenta_hash = ?
                ORDER BY fecha DESC, id DESC
                """;

        List<Mensaje> lista = new ArrayList<>();

        try (Connection conn = ConexionBD.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setString(1, cuentaHash);

            try (ResultSet rs = ps.executeQuery()) {
                while (rs.next()) {
                    Mensaje m = new Mensaje();
                    m.setRemitente(rs.getString("remitente"));
                    m.setAsunto(rs.getString("asunto"));
                    m.setCuerpo(rs.getString("cuerpo"));
                    m.setFecha(rs.getString("fecha"));
                    m.setCategoria(rs.getString("categoria"));
                    m.setPrioridad(rs.getString("prioridad"));
                    m.setUidImap(rs.getString("uid_imap")); // añade este campo en Mensaje si aún no existe
                    lista.add(m);
                }
            }
        }
        return lista;
    }

    // Insertar o actualizar una lista de mensajes (upsert por cuenta_hash + uid_imap)
    public void guardarOModificar(String cuentaHash, List<Mensaje> mensajes) throws SQLException {
        String sql = """
                INSERT INTO mensajes (cuenta_hash, uid_imap, remitente, asunto, cuerpo, fecha, categoria, prioridad)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
                ON CONFLICT(cuenta_hash, uid_imap) DO UPDATE SET
                    remitente = excluded.remitente,
                    asunto    = excluded.asunto,
                    cuerpo    = excluded.cuerpo,
                    fecha     = excluded.fecha,
                    categoria = excluded.categoria,
                    prioridad = excluded.prioridad;
                """;

        try (Connection conn = ConexionBD.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            for (Mensaje m : mensajes) {
                ps.setString(1, cuentaHash);
                ps.setString(2, m.getUidImap());
                ps.setString(3, m.getRemitente());
                ps.setString(4, m.getAsunto());
                ps.setString(5, m.getCuerpo());
                ps.setString(6, m.getFecha());      // en formato texto
                ps.setString(7, m.getCategoria());
                ps.setString(8, m.getPrioridad());
                ps.addBatch();
            }
            ps.executeBatch();
        }
    }

    // Borrar mensajes de una cuenta (por si quieres limpiar)
    public void borrarPorCuenta(String cuentaHash) throws SQLException {
        String sql = "DELETE FROM mensajes WHERE cuenta_hash = ?";

        try (Connection conn = ConexionBD.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setString(1, cuentaHash);
            ps.executeUpdate();
        }
    }
}
