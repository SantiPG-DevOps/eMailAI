package com.emailAI.controller;

import com.emailAI.dao.DAOMensajes;
import com.emailAI.model.Mensaje;
import com.emailAI.service.MailService;
import javafx.application.Platform;
import javafx.collections.FXCollections;
import javafx.concurrent.Task;
import javafx.fxml.FXML;
import javafx.scene.control.*;
import javafx.scene.web.WebView;

import java.util.ArrayList;
import java.util.List;

public class CorreoController {

    @FXML
    ListView<Mensaje> lstMensajes;

    @FXML
    private Label lblAsunto;

    @FXML
    private Label lblRemitente;

    @FXML
    private WebView webViewCuerpo;

    @FXML
    private TextArea txtCuerpo;

    @FXML
    private Button btnReentrenar;

    @FXML
    private Button btnSpam;

    @FXML
    private Button btnLegitimo;

    @FXML
    private Button btnSug1;

    @FXML
    private Button btnSug2;

    @FXML
    private Button btnSug3;

    @FXML
    private Button btnAnularSub;

    @FXML
    private Button btnActualizar;

    @FXML
    private Button btnBorrarSeleccionado;

    private MailService mailService;
    private String cuentaHash;

    @FXML
    private void initialize() {
        lstMensajes.setCellFactory(list -> new ListCell<>() {
            @Override
            protected void updateItem(Mensaje msg, boolean empty) {
                super.updateItem(msg, empty);

                if (empty || msg == null) {
                    setText(null);
                    getStyleClass().removeAll("message-card", "message-card-spam");
                    return;
                }

                String remitente = msg.getRemitente() != null ? msg.getRemitente() : "";
                String asunto    = msg.getAsunto() != null ? msg.getAsunto() : "";

                setText(remitente + "\n" + asunto);

                getStyleClass().removeAll("message-card", "message-card-spam");
                if ("SPAM".equalsIgnoreCase(msg.getCategoria())) {
                    getStyleClass().add("message-card-spam");
                } else {
                    getStyleClass().add("message-card");
                }
            }
        });

        lstMensajes.getSelectionModel().selectedItemProperty().addListener(
                (obs, oldSel, newSel) -> mostrarMensaje(newSel)
        );
    }

    public void setMailService(MailService mailService) {
        this.mailService = mailService;
        if (mailService != null) {
            this.cuentaHash = mailService.getCuentaHash();
        }
    }

    // Entrar en Correo o Enviar/Recibir
    public void cargarBandejaEntradaAsync() {
        cargarDesdeBD();   // primero local

        if (mailService == null || cuentaHash == null) return;

        Task<Void> task = new Task<>() {
            @Override
            protected Void call() {
                try {
                    List<Mensaje> mensajesImap = mailService.listInbox();

                    try {
                        DAOMensajes dao = new DAOMensajes();
                        dao.guardarOModificar(cuentaHash, mensajesImap);
                    } catch (Exception e) {
                        e.printStackTrace();
                    }

                    List<Mensaje> mensajesActualizados = new ArrayList<>();
                    try {
                        DAOMensajes dao = new DAOMensajes();
                        mensajesActualizados.addAll(dao.listarPorCuenta(cuentaHash));
                    } catch (Exception e) {
                        e.printStackTrace();
                        mensajesActualizados = mensajesImap;
                    }

                    List<Mensaje> finalLista = mensajesActualizados;

                    Platform.runLater(() -> {
                        lstMensajes.setItems(FXCollections.observableArrayList(finalLista));
                        if (!finalLista.isEmpty()) {
                            lstMensajes.getSelectionModel().selectFirst();
                        } else {
                            limpiarDetalle();
                        }
                    });
                } catch (Exception e) {
                    e.printStackTrace();
                    Platform.runLater(() ->
                            System.err.println("Error sincronizando bandeja: " + e.getMessage())
                    );
                }
                return null;
            }
        };

        Thread t = new Thread(task, "sync-bandeja");
        t.setDaemon(true);
        t.start();
    }

    private void cargarDesdeBD() {
        if (cuentaHash == null) return;
        try {
            DAOMensajes dao = new DAOMensajes();
            List<Mensaje> lista = dao.listarPorCuenta(cuentaHash);
            lstMensajes.setItems(FXCollections.observableArrayList(lista));
            if (!lista.isEmpty()) {
                lstMensajes.getSelectionModel().selectFirst();
            } else {
                limpiarDetalle();
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    private void limpiarDetalle() {
        lblAsunto.setText("");
        lblRemitente.setText("");
        webViewCuerpo.getEngine().loadContent("");
        txtCuerpo.clear();
    }

    private void mostrarMensaje(Mensaje msg) {
        if (msg == null) {
            limpiarDetalle();
            return;
        }

        lblAsunto.setText(msg.getAsunto());
        lblRemitente.setText(msg.getRemitente());

        String html  = msg.getHtml();
        String texto = msg.getCuerpo();

        if (html != null && !html.isBlank()) {
            webViewCuerpo.setVisible(true);
            webViewCuerpo.setManaged(true);
            webViewCuerpo.getEngine().loadContent(html, "text/html");

            txtCuerpo.setVisible(false);
            txtCuerpo.setManaged(false);
        } else {
            txtCuerpo.setVisible(true);
            txtCuerpo.setManaged(true);
            txtCuerpo.setText(texto != null ? texto : "");

            webViewCuerpo.setVisible(false);
            webViewCuerpo.setManaged(false);
        }
    }

    @FXML
    private void onRedactar() {}

    @FXML
    private void onActualizarBandeja() {
        cargarBandejaEntradaAsync();
    }

    @FXML
    private void onResponder() {}

    @FXML
    private void onResponderTodos() {}

    @FXML
    private void onReenviar() {}

    @FXML
    private void onBorrarMensajeSeleccionado() {
        Mensaje seleccionado = lstMensajes.getSelectionModel().getSelectedItem();
        if (seleccionado == null || mailService == null) {
            return;
        }

        try {
            mailService.eliminarMensaje(seleccionado);
            lstMensajes.getItems().remove(seleccionado);
            limpiarDetalle();
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    @FXML private void onReentrenarModelo() {}
    @FXML private void onMarcarSpam() {}
    @FXML private void onMarcarLegitimo() {}
    @FXML private void onUsarRespuesta1() {}
    @FXML private void onUsarRespuesta2() {}
    @FXML private void onUsarRespuesta3() {}
    @FXML private void onAnularSub() {}
}