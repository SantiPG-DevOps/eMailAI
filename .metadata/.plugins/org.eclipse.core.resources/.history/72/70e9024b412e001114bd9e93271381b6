            """;

        List<Mensaje> lista = new ArrayList<>();

        try (Connection conn = ConexionBD.getConnectionArchivoCorreos(anio);
             PreparedStatement ps = conn.prepareStatement(sql);
             ResultSet rs = ps.executeQuery()) {

