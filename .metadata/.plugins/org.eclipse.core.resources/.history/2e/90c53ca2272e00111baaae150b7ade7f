/* -------------------------
   Paleta corporativa - CLARO
   ------------------------- */

/* Fondos principales y secundarios */
.root {
    -fx-background-color: #E8ECEF; /* Plata Claro */
    -fx-font-family: "Segoe UI", "Roboto", "Sans-Serif";
    -fx-text-fill: #1E3A5F; /* Azul Corporativo Oscuro */
}

/* Título principal eMailAI */
.title-label {
    -fx-font-size: 26px;
    -fx-font-weight: bold;
    -fx-text-fill: #1E3A5F; /* Azul Corporativo Oscuro */
}

/* Etiquetas de sección ("Cuentas guardadas", "Contraseña") */
.section-label {
    -fx-font-size: 14px;
    -fx-font-weight: bold;
    -fx-text-fill: #1E3A5F;
}

/* Texto general (por si lo usas) */
.label {
    -fx-text-fill: #1E3A5F;
}

.label-secondary {
    -fx-text-fill: #5C6B7A;
    -fx-font-size: 12px;
}

/* Barra lateral principal */
.main-app-sidebar {
    -fx-background-color: #F4F6F8;
    -fx-border-color: transparent #D1D5DB transparent transparent;
    -fx-border-width: 0 1 0 0;
}

.main-sidebar-brand {
    -fx-font-size: 16px;
    -fx-font-weight: bold;
    -fx-text-fill: #1E3A5F;
}

.main-nav-heading {
    -fx-text-fill: #5C6B7A;
}

.main-nav-submenu-heading {
    -fx-text-fill: #6B7280;
    -fx-padding: 4 0 2 4;
}

.main-nav-submenu {
    -fx-background-color: transparent;
}

.toggle-button.main-nav-primary {
    -fx-background-radius: 8;
    -fx-padding: 10 12;
    -fx-font-size: 13px;
    -fx-max-width: Infinity;
    -fx-content-display: LEFT;
    -fx-background-color: transparent;
    -fx-text-fill: #1E3A5F;
    -fx-border-color: transparent;
    -fx-border-width: 0;
}

.toggle-button.main-nav-primary:hover {
    -fx-background-color: #E0F2FE;
}

.toggle-button.main-nav-primary:selected {
    -fx-background-color: #0891B2;
    -fx-text-fill: white;
}

.main-nav-folder-list {
    -fx-background-color: transparent;
    -fx-border-width: 0;
    -fx-padding: 0;
}

.main-nav-folder-list .list-cell {
    -fx-background-insets: 2 4;
    -fx-padding: 0 8 0 8;
    -fx-background-radius: 6;
    -fx-text-fill: #374151;
    -fx-font-size: 12px;
    -fx-background-color: transparent;
}

.main-nav-folder-list .list-cell:filled:hover {
    -fx-background-color: #E0F2FE;
}

.main-nav-folder-list .list-cell:filled:selected,
.main-nav-folder-list .list-cell:filled:selected:focused {
    -fx-background-color: #0891B2;
    -fx-text-fill: white;
}

.config-root {
    -fx-background-color: #E8ECEF;
}

.config-header-wrap {
    -fx-background-color: #FFFFFF;
    -fx-border-color: #B8BEC4;
}

.config-footer-wrap {
    -fx-background-color: #FFFFFF;
    -fx-border-color: transparent transparent #B8BEC4 transparent;
}

.config-screen-title {
    -fx-text-fill: #1E3A5F;
}

.config-page-heading {
    -fx-text-fill: #1E3A5F;
}

.config-section-kicker {
    -fx-text-fill: #1E3A5F;
}

.config-field-label {
    -fx-text-fill: #374151;
}

.config-nav-heading {
    -fx-text-fill: #5C6B7A;
}

.config-header-accent {
    -fx-background-color: #0891B2;
    -fx-background-radius: 3;
}

.config-nav-pane {
    -fx-background-color: #F4F6F8;
    -fx-border-color: transparent #D1D5DB transparent transparent;
    -fx-border-width: 0 1 0 0;
}

.config-content-stack {
    -fx-background-color: #E8ECEF;
}

.config-section-box {
    -fx-background-color: #FFFFFF;
    -fx-border-color: #D1D5DB #D1D5DB #D1D5DB #0891B2;
    -fx-border-width: 1 1 1 4;
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 2);
}

.config-nav-list {
    -fx-background-color: transparent;
}

.config-nav-list .list-cell {
    -fx-background-color: transparent;
    -fx-text-fill: #1E3A5F;
}

.config-nav-list .list-cell:filled:hover {
    -fx-background-color: #E0F2FE;
}

.config-nav-list .list-cell:filled:selected,
.config-nav-list .list-cell:filled:selected:focused {
    -fx-background-color: #0891B2;
    -fx-text-fill: white;
}

.config-split > .split-pane-divider {
    -fx-background-color: #D1D5DB;
}

/* Mensajes de estado */
.status-label {
    -fx-text-fill: #0891B2; /* Azul Tecnológico */
    -fx-font-size: 11px;
}

/* -------------------------
   Botones
   ------------------------- */

.button {
    -fx-background-radius: 8;
    -fx-padding: 6 14 6 14;
    -fx-background-color: #0891B2; /* Azul TecnológiAco */
    -fx-text-fill: white;
    -fx-font-weight: bold;
}

.button:hover {
    -fx-background-color: #06B6D4; /* Cyan Brillante */
}

.button:pressed {
    -fx-background-color: #1E3A5F; /* Azul Corporativo Oscuro */
}

/* Botón toggle tema Claro/Oscuro */
.toggle-button {
    -fx-background-radius: 999;
    -fx-background-color: #B8BEC4; /* Gris Metálico */
    -fx-text-fill: #1E3A5F;
}

.toggle-button:selected {
    -fx-background-color: #0891B2; /* Azul Tecnológico */
    -fx-text-fill: white;
}

/* -------------------------
   Campos de texto
   ------------------------- */

.text-field,
.password-field {
    -fx-background-color: white;
    -fx-background-radius: 6;
    -fx-border-radius: 6;
    -fx-border-color: #B8BEC4; /* Gris Metálico */
    -fx-border-width: 1;
    -fx-text-fill: #1E3A5F;
}

.text-field:focused,
.password-field:focused {
    -fx-border-color: #06B6D4; /* Cyan Brillante */
    -fx-border-width: 2;
}

/* -------------------------
   Tarjetas cuentas (login)
   ------------------------- */

.account-card {
    -fx-padding: 10;
    -fx-background-radius: 12;
    -fx-background-color: #E8ECEF; /* Plata Claro */
    -fx-border-color: #B8BEC4;     /* Gris Metálico */
    -fx-border-radius: 12;
    -fx-border-width: 1;
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
    -fx-cursor: hand;
}

.account-card:hover {
    -fx-background-color: #06B6D4; /* Cyan Brillante */
}

.account-card-selected {
    -fx-background-color: #0891B2; /* Azul Tecnológico */
    -fx-border-color: #1E3A5F;
}

.account-email {
    -fx-font-weight: bold;
    -fx-text-fill: #1E3A5F;
}

.account-server {
    -fx-font-size: 11px;
    -fx-text-fill: #4b5563; /* gris más oscuro */
}

/* Tarjeta "+ Añadir cuenta" */
.account-card-new {
    -fx-padding: 10;
    -fx-background-radius: 12;
    -fx-background-color: #B8BEC4; /* Gris Metálico */
    -fx-border-radius: 12;
    -fx-border-color: #0891B2;     /* Azul Tecnológico */
    -fx-border-width: 1;
    -fx-cursor: hand;
}

.account-card-new:hover {
    -fx-background-color: #06B6D4; /* Cyan Brillante */
}

.account-new-label {
    -fx-font-weight: bold;
    -fx-text-fill: #1E3A5F;
}

/* Fondo transparente para el scroll de cuentas en tema claro */
.accounts-scroll {
    -fx-background-color: transparent;
    -fx-background-insets: 0;
    -fx-padding: 0;
}

.accounts-scroll > .viewport {
    -fx-background-color: transparent;
}

#accountsList {
    -fx-background-color: transparent;
}

/* Tarjeta SPAM */
.list-cell.message-card-spam {
    -fx-background-color: #1F2933;
    -fx-text-fill: #FCA5A5;
    -fx-padding: 6 10 6 10;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
}

.list-cell.message-card-spam:selected {
    -fx-background-color: #DC2626;
    -fx-text-fill: #F9FAFB;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
}

.list-cell.message-card-risk {
    -fx-background-color: #FEF2F2;
    -fx-text-fill: #991B1B;
    -fx-padding: 6 10 6 10;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-border-width: 0 0 0 4;
    -fx-border-color: transparent transparent transparent #DC2626;
}

.list-cell.message-card-risk:selected {
    -fx-background-color: #FECACA;
    -fx-text-fill: #450A0A;
}

.list-cell.message-card-pending {
    -fx-background-color: #FFFBEB;
    -fx-text-fill: #92400E;
    -fx-padding: 6 10 6 10;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-border-width: 0 0 0 4;
    -fx-border-color: transparent transparent transparent #F59E0B;
}

.list-cell.message-card-pending:selected {
    -fx-background-color: #FDE68A;
    -fx-text-fill: #451A03;
}

.list-cell.message-card-legit {
    -fx-background-color: #F0FDF4;
    -fx-text-fill: #166534;
    -fx-padding: 6 10 6 10;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-border-width: 0 0 0 4;
    -fx-border-color: transparent transparent transparent #22C55E;
}

.list-cell.message-card-legit:selected {
    -fx-background-color: #BBF7D0;
    -fx-text-fill: #14532D;
}

.sidebar-submenu-toggle {
    -fx-background-color: #FFFFFF;
    -fx-text-fill: #1E3A5F;
    -fx-border-color: #B8BEC4;
    -fx-border-width: 1;
    -fx-border-radius: 8;
}

.sidebar-submenu-toggle:selected {
    -fx-background-color: #E0F2FE;
    -fx-text-fill: #0C4A6E;
    -fx-border-color: #0891B2;
}

/* -------------------------
   CONTACTOS
   ------------------------- */

/* La celda en sí (fondo transparente para que solo se vea la tarjeta) */
.list-cell.contact-card-cell {
    -fx-background-color: transparent;
    -fx-text-fill: #1E3A5F;
}

/* Tarjeta de contacto */
.contact-card {
    -fx-background-color: #FFFFFF;      /* Blanco tarjeta */
    -fx-border-color: #B8BEC4;          /* Gris Metálico */
    -fx-background-radius: 10;
    -fx-border-radius: 10;
    -fx-border-width: 1;
}

/* Selección de tarjeta */
.list-cell:filled:selected .contact-card,
.list-cell:filled:selected:focused .contact-card {
    -fx-background-color: #0891B2;      /* Azul Tecnológico */
    -fx-border-color: #1E3A5F;
}

/* Textos dentro de la tarjeta */
.contact-name {
    -fx-text-fill: #1E3A5F;
    -fx-font-weight: bold;
}

.contact-email {
    -fx-text-fill: #4b5563;
    -fx-font-size: 11px;
}

.contact-phone {
    -fx-text-fill: #1E3A5F;
}

/* Config: botones pie (sobrescriben .button genérico) */
.button.config-primary-btn {
    -fx-font-size: 13px;
    -fx-font-weight: bold;
    -fx-padding: 10 20 10 20;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-background-color: #0891B2;
    -fx-text-fill: white;
    -fx-border-color: transparent;
}

.button.config-primary-btn:hover {
    -fx-background-color: #06B6D4;
}

.button.config-secondary-btn {
    -fx-font-size: 13px;
    -fx-padding: 10 16 10 16;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-background-color: white;
    -fx-text-fill: #1E3A5F;
    -fx-border-color: #B8BEC4;
    -fx-border-width: 1;
}

.button.config-secondary-btn:hover {
    -fx-background-color: #F4F6F8;
    -fx-border-color: #0891B2;
}