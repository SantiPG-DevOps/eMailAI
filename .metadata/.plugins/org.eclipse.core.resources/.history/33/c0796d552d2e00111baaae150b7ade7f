package com.emailAI.controller;

import com.emailAI.dao.DAOContactos;
import com.emailAI.model.Contacto;
import javafx.collections.FXCollections;
import javafx.event.ActionEvent;
import javafx.fxml.FXML;
import javafx.geometry.Insets;
import javafx.geometry.VPos;
import javafx.scene.control.*;
import javafx.scene.layout.*;
import javafx.stage.Modality;

import java.util.*;

public class ContactosController {

    // ── FXML ─────────────────────────────────────────────────────────────────
    @FXML private ListView<Contacto> lstCol1;
    @FXML private ListView<Contacto> lstCol2;
    @FXML private ListView<Contacto> lstCol3;
    @FXML private Label     lblEstado;
    @FXML private Label     lblPagina;
    @FXML private Button    btnEditar;
    @FXML private Button    btnBorrar;
    @FXML private Button    btnPrimera;
    @FXML private Button    btnAnterior;
    @FXML private Button    btnSiguiente;
    @FXML private Button    btnUltima;
    @FXML private TextField txtBuscar;

    // ── Estado ────────────────────────────────────────────────────────────────
    private DAOContactos daoContactos;
    private final List<Contacto> todos    = new ArrayList<>();
    private final List<Contacto> filtrado = new ArrayList<>();

    private Contacto contactoSeleccionado;

    private static final int POR_PAGINA = 30; // 10 filas × 3 columnas
    private int paginaActual = 0;
    private int totalPaginas = 1;

    // ── Init ──────────────────────────────────────────────────────────────────
    @FXML
    private void initialize() {
        daoContactos = new DAOContactos("jdbc:sqlite:emailAI.db");
        configurarLista(lstCol1);
        configurarLista(lstCol2);
        configurarLista(lstCol3);
        cargarContactos();
    }

    // ── Cell factory + listener selección ────────────────────────────────────
    private void configurarLista(ListView<Contacto> lista) {
        lista.setCellFactory(lv -> new ContactoCell());
        lista.getSelectionModel().selectedItemProperty().addListener((obs, old, sel) -> {
            if (sel == null) return;
            if (esSeparador(sel)) {
                lista.getSelectionModel().clearSelection();
                return;
            }
            contactoSeleccionado = sel;
            deselectOtras(lista);
            actualizarBotones();
            if (lblEstado != null) lblEstado.setText("");
        });
    }

    private void deselectOtras(ListView<Contacto> activa) {
        if (activa != lstCol1) lstCol1.getSelectionModel().clearSelection();
        if (activa != lstCol2) lstCol2.getSelectionModel().clearSelection();
        if (activa != lstCol3) lstCol3.getSelectionModel().clearSelection();
    }

    private void actualizarBotones() {
        boolean hay = contactoSeleccionado != null;
        if (btnEditar != null) btnEditar.setDisable(!hay);
        if (btnBorrar != null) btnBorrar.setDisable(!hay);
    }

    // ── Carga ─────────────────────────────────────────────────────────────────
    private void cargarContactos() {
        todos.clear();
        todos.addAll(daoContactos.listarTodos());

        // Ordena: apellido → nombre, sin tildes ni mayúsculas
        todos.sort((a, b) -> {
            String ka = normalize(safe(a.getApellido()) + " " + safe(a.getNombre()));
            String kb = normalize(safe(b.getApellido()) + " " + safe(b.getNombre()));
            return ka.compareTo(kb);
        });

        aplicarFiltro();
    }

    // ── Filtro y paginación ───────────────────────────────────────────────────
    private void aplicarFiltro() {
        String q = txtBuscar != null ? normalize(txtBuscar.getText().trim()) : "";
        filtrado.clear();
        if (q.isEmpty()) {
            filtrado.addAll(todos);
        } else {
            for (Contacto c : todos) {
                if (normalize(safe(c.getApellido())).contains(q)
                        || normalize(safe(c.getNombre())).contains(q)
                        || normalize(safe(c.getEmail())).contains(q)
                        || safe(c.getTelefono()).contains(q)) {
                    filtrado.add(c);
                }
            }
        }
        paginaActual = 0;
        totalPaginas = Math.max(1, (int) Math.ceil(filtrado.size() / (double) POR_PAGINA));
        mostrarPagina();
    }

    private void mostrarPagina() {
        int desde = paginaActual * POR_PAGINA;
        int hasta = Math.min(desde + POR_PAGINA, filtrado.size());
        List<Contacto> pagina = new ArrayList<>(filtrado.subList(desde, hasta));

        List<Contacto> conSep = insertarSeparadores(pagina);

        // Cuenta contactos reales (no separadores) para dividir en 3 columnas iguales
        long reales = conSep.stream().filter(c -> !esSeparador(c)).count();
        int porCol = (int) Math.ceil(reales / 3.0);

        List<Contacto> c1 = new ArrayList<>();
        List<Contacto> c2 = new ArrayList<>();
        List<Contacto> c3 = new ArrayList<>();

        int contador = 0;
        for (Contacto c : conSep) {
            if (!esSeparador(c)) contador++;

            if (contador <= porCol) {
                c1.add(c);
            } else if (contador <= porCol * 2) {
                c2.add(c);
            } else {
                c3.add(c);
            }
        }

        lstCol1.setItems(FXCollections.observableArrayList(c1));
        lstCol2.setItems(FXCollections.observableArrayList(c2));
        lstCol3.setItems(FXCollections.observableArrayList(c3));

        if (lblPagina != null)
            lblPagina.setText("Pág. " + (paginaActual + 1) + " / " + totalPaginas);
        if (btnPrimera   != null) btnPrimera.setDisable(paginaActual == 0);
        if (btnAnterior  != null) btnAnterior.setDisable(paginaActual == 0);
        if (btnSiguiente != null) btnSiguiente.setDisable(paginaActual >= totalPaginas - 1);
        if (btnUltima    != null) btnUltima.setDisable(paginaActual >= totalPaginas - 1);

        contactoSeleccionado = null;
        actualizarBotones();
    }

    // Inserta contactos-separador antes de cada nueva letra inicial de apellido/nombre
    private List<Contacto> insertarSeparadores(List<Contacto> lista) {
        List<Contacto> resultado = new ArrayList<>();
        String letraActual = "";
        for (Contacto c : lista) {
            String base = (c.getApellido() != null && !c.getApellido().isBlank())
                    ? c.getApellido().trim()
                    : safe(c.getNombre());
            String inicial = base.isEmpty() ? "#"
                    : normalize(base.substring(0, 1)).toUpperCase();
            if (!inicial.equals(letraActual)) {
                letraActual = inicial;
                // Separador: id=null, nombre=null, apellido=null, email=inicial
                resultado.add(new Contacto(null, null, null, inicial, null, null));
            }
            resultado.add(c);
        }
        return resultado;
    }

    // Un contacto es separador si nombre==null y apellido==null
    private static boolean esSeparador(Contacto c) {
        return c != null && c.getNombre() == null && c.getApellido() == null;
    }

    // ── Búsqueda ──────────────────────────────────────────────────────────────
    @FXML private void onBuscar() { aplicarFiltro(); }

    // ── Paginación ────────────────────────────────────────────────────────────
    @FXML private void onPrimera()   { paginaActual = 0;                      mostrarPagina(); }
    @FXML private void onAnterior()  { if (paginaActual > 0) paginaActual--;  mostrarPagina(); }
    @FXML private void onSiguiente() { if (paginaActual < totalPaginas - 1) paginaActual++; mostrarPagina(); }
    @FXML private void onUltima()    { paginaActual = totalPaginas - 1;       mostrarPagina(); }

    // ── CRUD ──────────────────────────────────────────────────────────────────
    @FXML private void onNuevoContacto()  { abrirDialogoEdicion(null); }

    @FXML
    private void onEditarContacto() {
        if (contactoSeleccionado == null) {
            if (lblEstado != null) lblEstado.setText("Selecciona un contacto.");
            return;
        }
        abrirDialogoEdicion(contactoSeleccionado);
    }

    @FXML
    private void onBorrarContacto() {
        if (contactoSeleccionado == null) {
            if (lblEstado != null) lblEstado.setText("Selecciona un contacto.");
            return;
        }
        Alert confirm = new Alert(Alert.AlertType.CONFIRMATION);
        confirm.setTitle("Borrar contacto");
        confirm.setHeaderText("¿Borrar \"" + contactoSeleccionado.getNombreCompleto() + "\"?");
        confirm.setContentText("Esta acción no se puede deshacer.");
        var res = confirm.showAndWait();
        if (res.isEmpty() || res.get() != ButtonType.OK) return;

        daoContactos.borrar(contactoSeleccionado);
        contactoSeleccionado = null;
        actualizarBotones();
        cargarContactos();
        if (lblEstado != null) lblEstado.setText("Contacto borrado.");
    }

    private void abrirDialogoEdicion(Contacto contacto) {
        try {
            Dialog<ButtonType> dialog = new Dialog<>();
            dialog.setTitle(contacto == null ? "Nuevo contacto" : "Editar contacto");
            dialog.initModality(Modality.APPLICATION_MODAL);

            GridPane grid = new GridPane();
            grid.setHgap(10);
            grid.setVgap(10);
            grid.setPadding(new Insets(16, 20, 12, 20));

            ColumnConstraints col0 = new ColumnConstraints();
            col0.setMinWidth(80);
            ColumnConstraints col1 = new ColumnConstraints();
            col1.setHgrow(Priority.ALWAYS);
            col1.setMinWidth(260);
            grid.getColumnConstraints().addAll(col0, col1);

            TextField fNombre   = new TextField(contacto != null ? safe(contacto.getNombre())   : "");
            TextField fApellido = new TextField(contacto != null ? safe(contacto.getApellido()) : "");
            TextField fEmail    = new TextField(contacto != null ? safe(contacto.getEmail())    : "");
            TextField fTelefono = new TextField(contacto != null ? safe(contacto.getTelefono()) : "");
            TextArea  fNotas    = new TextArea (contacto != null ? safe(contacto.getNotas())    : "");

            fNombre.setPromptText("Nombre");
            fApellido.setPromptText("Apellido(s)");
            fEmail.setPromptText("correo@ejemplo.com");
            fTelefono.setPromptText("+34 600 000 000");
            fNotas.setPrefRowCount(4);
            fNotas.setWrapText(true);

            Label lNotas = new Label("Notas:");
            GridPane.setValignment(lNotas, VPos.TOP);

            grid.add(new Label("Nombre:"),   0, 0); grid.add(fNombre,   1, 0);
            grid.add(new Label("Apellido:"), 0, 1); grid.add(fApellido, 1, 1);
            grid.add(new Label("Email:"),    0, 2); grid.add(fEmail,    1, 2);
            grid.add(new Label("Teléfono:"), 0, 3); grid.add(fTelefono, 1, 3);
            grid.add(lNotas,                 0, 4); grid.add(fNotas,    1, 4);

            dialog.getDialogPane().setContent(grid);
            dialog.getDialogPane().getButtonTypes().setAll(ButtonType.CANCEL, ButtonType.OK);

            if (lstCol1.getScene() != null)
                dialog.getDialogPane().getStylesheets().setAll(lstCol1.getScene().getStylesheets());

            Button okBtn = (Button) dialog.getDialogPane().lookupButton(ButtonType.OK);
            okBtn.addEventFilter(ActionEvent.ACTION, ev -> {
                if (fNombre.getText().isBlank()) {
                    ev.consume();
                    if (lblEstado != null) lblEstado.setText("El nombre es obligatorio.");
                }
            });

            var res = dialog.showAndWait();
            if (res.isEmpty() || res.get() != ButtonType.OK) return;

            if (contacto == null) {
                Contacto nuevo = new Contacto(
                        null,
                        fNombre.getText().trim(),
                        safe(fApellido.getText()),
                        safe(fEmail.getText()),
                        safe(fTelefono.getText()),
                        safe(fNotas.getText()));
                daoContactos.guardarOActualizar(nuevo);
                if (lblEstado != null) lblEstado.setText("Contacto creado.");
            } else {
                contacto.setNombre(fNombre.getText().trim());
                contacto.setApellido(safe(fApellido.getText()));
                contacto.setEmail(safe(fEmail.getText()));
                contacto.setTelefono(safe(fTelefono.getText()));
                contacto.setNotas(safe(fNotas.getText()));
                daoContactos.guardarOActualizar(contacto);
                if (lblEstado != null) lblEstado.setText("Contacto actualizado.");
            }

            cargarContactos();

        } catch (Exception e) {
            e.printStackTrace();
            if (lblEstado != null) lblEstado.setText("Error: " + e.getMessage());
        }
    }

    // ── Cell personalizada ────────────────────────────────────────────────────
    private static class ContactoCell extends ListCell<Contacto> {
        @Override
        protected void updateItem(Contacto c, boolean empty) {
            super.updateItem(c, empty);
            getStyleClass().removeAll("contact-separator-cell", "contact-card-cell");

            if (empty || c == null) {
                setText(null);
                setGraphic(null);
                setMouseTransparent(false);
                return;
            }

            // Separador de letra
            if (esSeparador(c)) {
                setText(null);
                Label lbl = new Label(c.getEmail()); // email almacena la inicial
                lbl.getStyleClass().add("contact-separator-label");
                setGraphic(lbl);
                getStyleClass().add("contact-separator-cell");
                setMouseTransparent(true);
                return;
            }

            // Fila normal
            HBox row = new HBox(10);
            row.setPickOnBounds(false);

            VBox info = new VBox(1);

            // Muestra "Apellido, Nombre" o solo nombre
            Label lblNombre = new Label(c.getNombreCompleto());
            lblNombre.getStyleClass().add("contact-name");
            info.getChildren().add(lblNombre);

            if (!safe(c.getEmail()).isBlank()) {
                Label lblEmail = new Label(c.getEmail());
                lblEmail.getStyleClass().add("contact-email");
                info.getChildren().add(lblEmail);
            }

            Label lblTel = new Label(safe(c.getTelefono()));
            lblTel.getStyleClass().add("contact-phone");

            HBox.setHgrow(info, Priority.ALWAYS);
            row.getChildren().addAll(info, lblTel);

            setText(null);
            setGraphic(row);
            getStyleClass().add("contact-card-cell");
            setMouseTransparent(false);
        }

        private static boolean esSeparador(Contacto c) {
            return c.getNombre() == null && c.getApellido() == null;
        }

        private static String safe(String s) { return s != null ? s : ""; }
    }

    // ── Utilidades ────────────────────────────────────────────────────────────
    private static String normalize(String s) {
        if (s == null) return "";
        return java.text.Normalizer.normalize(s, java.text.Normalizer.Form.NFD)
                .replaceAll("\\p{InCombiningDiacriticalMarks}+", "")
                .toLowerCase();
    }

    private static String safe(String s) { return s != null ? s.trim() : ""; }
}