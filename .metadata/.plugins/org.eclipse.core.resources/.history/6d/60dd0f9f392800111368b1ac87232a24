    @FXML
    private void onBorrarMensajeSeleccionado() {
        Mensaje seleccionado = lstMensajes.getSelectionModel().getSelectedItem();
        if (seleccionado == null || mailService == null) {
            return;
        }

        try {
            mailService.eliminarMensaje(seleccionado);

            // quitar de BD
            try {
                DAOMensajes dao = new DAOMensajes();
                List<Mensaje> soloEste = List.of(seleccionado);
                // truco rápido: marcarlo con categoría especial y que un futuro método lo borre;
                // o mejor, añades en DAOMensajes un deletePorUid(...) si quieres hacerlo fino
            } catch (Exception e) {
                e.printStackTrace();
            }

            lstMensajes.getItems().remove(seleccionado);
            limpiarDetalle();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

