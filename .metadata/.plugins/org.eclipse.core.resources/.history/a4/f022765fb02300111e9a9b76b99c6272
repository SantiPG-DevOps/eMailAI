<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="555.0" prefWidth="800"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.emailAI.controller.LoginController">

    <!-- CONTENIDO CENTRADO -->
    <center>
        <VBox alignment="CENTER" prefHeight="532.0" prefWidth="800.0" spacing="32">
            <padding>
                <Insets bottom="40" left="40" right="40" top="40" />
            </padding>

            <!-- Título + logo -->
            <VBox alignment="CENTER" prefHeight="82.0" prefWidth="720.0" spacing="8">
                <Label styleClass="title-label" text="eMailAI" />
                <ImageView fx:id="logoImage" fitHeight="80" preserveRatio="true" />
            </VBox>

            <!-- Cuentas guardadas: lista centrada al 70% -->
            <VBox alignment="CENTER" maxWidth="Infinity" spacing="5.0">
                <HBox alignment="CENTER" maxWidth="560" spacing="10">
                    <Label styleClass="section-label" text="Cuentas guardadas" />
                    <Pane HBox.hgrow="ALWAYS" />
                    <Button fx:id="newAccountButton"
                            onAction="#onNewAccountClicked"
                            styleClass="small-button"
                            text="+ Añadir cuenta" />
                </HBox>

                <VBox alignment="CENTER" maxWidth="560">
                    <ScrollPane fx:id="accountsScroll"
                                fitToWidth="true"
                                prefViewportHeight="220"
                                styleClass="accounts-scroll">
                        <content>
                            <VBox fx:id="accountsList"
                                  alignment="CENTER"
                                  maxWidth="560"
                                  spacing="8" />
                        </content>
                    </ScrollPane>
                </VBox>
                <padding>
                    <Insets bottom="15.0" />
                </padding>
            </VBox>

            <!-- Contraseña app + botón Entrar + fuerza -->
            <VBox alignment="CENTER" maxWidth="560" spacing="8">
                <Label styleClass="section-label"
                       text="Contraseña de la aplicación" />

                <PasswordField fx:id="passwordField"
                               maxWidth="400"
                               promptText="Introduce la contraseña de la app"
                               styleClass="text-field login-password"
                               onKeyReleased="#onAppPasswordChanged" />

                <!-- Medidor de fuerza -->
                <VBox spacing="4" maxWidth="400">
                    <ProgressBar fx:id="strengthBar"
                                 prefWidth="400"
                                 progress="0.0" />
                    <Label fx:id="strengthLabel"
                           text="Contraseña débil" />
                </VBox>

                <Button fx:id="loginButton"
                        defaultButton="true"
                        maxWidth="400"
                        onAction="#onLoginClicked"
                        styleClass="primary-button"
                        text="Entrar" />

                <Label fx:id="statusLabel"
                       styleClass="status-label"
                       text="" />
            </VBox>
        </VBox>
    </center>

    <!-- ABAJO: toggle de tema centrado -->
    <bottom>
        <HBox alignment="CENTER" prefHeight="49.0" prefWidth="800.0" spacing="10">
            <padding>
                <Insets bottom="20" left="20" right="20" top="10" />
            </padding>
            <ToggleButton fx:id="themeToggle"
                          onAction="#onThemeToggle"
                          styleClass="theme-toggle" />
        </HBox>
    </bottom>

</BorderPane>
