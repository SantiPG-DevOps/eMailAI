<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.emailAI.controller.TareasController">

    <center>
        <BorderPane>

            <!-- ZONA SUPERIOR: filtros tipo Todoist -->
            <top>
                <VBox spacing="6">
                    <padding>
                        <Insets top="10" left="10" right="10" bottom="6"/>
                    </padding>

                    <!-- Línea 1: Hoy / Mañana -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <children>
                            <Label text="Tareas" styleClass="section-label"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <ToggleButton text="Hoy"    fx:id="btnHoy"    onAction="#onFiltroHoy"    styleClass="chip"/>
                            <ToggleButton text="Mañana" fx:id="btnManana" onAction="#onFiltroManana" styleClass="chip"/>
                        </children>
                    </HBox>

                    <!-- Línea 2: Esta semana, este mes, planificado, etiquetas -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <children>
                            <Label text="Filtros:" styleClass="label-secondary"/>
                            <ToggleButton text="Semana"      fx:id="btnSemana"      onAction="#onFiltroSemana"      styleClass="chip"/>
                            <ToggleButton text="Mes"         fx:id="btnMes"         onAction="#onFiltroMes"         styleClass="chip"/>
                            <ToggleButton text="Planificado" fx:id="btnPlanificado" onAction="#onFiltroPlanificado" styleClass="chip"/>
                            <ToggleButton text="Etiquetas"   fx:id="btnEtiquetas"   onAction="#onFiltroEtiquetas"   styleClass="chip"/>
                        </children>
                    </HBox>
                </VBox>
            </top>

            <!-- CENTRO: lista de tareas + detalle -->
            <center>
                <SplitPane dividerPositions="0.32">
                    <items>

                        <!-- Columna izquierda: lista de tareas + botones -->
                        <VBox spacing="8" minWidth="260">
                            <padding>
                                <Insets top="4" left="10" right="4" bottom="10"/>
                            </padding>

                            <children>
                                <HBox spacing="6">
                                    <children>
                                        <Label text="Bandeja de tareas" styleClass="label-secondary"/>
                                        <Pane HBox.hgrow="ALWAYS"/>
                                        <Button text="Nueva"  onAction="#onNuevaTarea"  styleClass="small-button"/>
                                        <Button text="Borrar" onAction="#onBorrarTarea" styleClass="small-button"/>
                                    </children>
                                </HBox>

                                <ListView fx:id="lstTareas" VBox.vgrow="ALWAYS"/>
                            </children>
                        </VBox>

                        <!-- Columna derecha: detalle / edición de tarea -->
                        <VBox spacing="8" minWidth="360">
                            <padding>
                                <Insets top="4" left="4" right="10" bottom="10"/>
                            </padding>

                            <children>
                                <GridPane hgap="8" vgap="8">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="80"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>

                                    <children>
                                        <Label text="Título:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTitulo" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                        <Label text="Fecha:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <DatePicker fx:id="dpFecha" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                        <Label text="Estado:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <ComboBox fx:id="cmbEstado"
                                                  GridPane.rowIndex="2"
                                                  GridPane.columnIndex="1"/>

                                        <Label text="Etiquetas:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtEtiquetas"
                                                   GridPane.rowIndex="3"
                                                   GridPane.columnIndex="1"
                                                   promptText="ej. trabajo,personal,urgente"/>

                                        <Label text="Descripción:" GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
                                        <TextArea fx:id="txtDescripcion"
                                                  GridPane.rowIndex="4"
                                                  GridPane.columnIndex="1"
                                                  prefRowCount="6"
                                                  wrapText="true"/>
                                    </children>
                                </GridPane>

                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                    <children>
                                        <Label fx:id="lblEstado" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        <Button text="Guardar" onAction="#onGuardarTarea" defaultButton="true"/>
                                    </children>
                                </HBox>

                                <!-- FUTURO: Integración Todoist / Calendario -->
                                <VBox spacing="4">
                                    <children>
                                        <Label text="Integraciones (pendiente implementar)" styleClass="label-secondary"/>
                                        <HBox spacing="8">
                                            <children>
                                                <Label text="Todoist" styleClass="label-secondary"/>
                                                <Label text="·" styleClass="label-secondary"/>
                                                <Label text="Calendario" styleClass="label-secondary"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </items>
                </SplitPane>
            </center>
        </BorderPane>
    </center>

</BorderPane>