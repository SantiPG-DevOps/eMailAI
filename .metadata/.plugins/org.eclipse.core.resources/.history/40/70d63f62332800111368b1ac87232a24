/* -------------------------
   Paleta corporativa - CLARO
   ------------------------- */

/* Fondos principales y secundarios */
.root {
    -fx-background-color: #E8ECEF; /* Plata Claro */
    -fx-font-family: "Segoe UI", "Roboto", "Sans-Serif";
    -fx-text-fill: #1E3A5F; /* Azul Corporativo Oscuro */
}

/* Título principal eMailAI */
.title-label {
    -fx-font-size: 26px;
    -fx-font-weight: bold;
    -fx-text-fill: #1E3A5F; /* Azul Corporativo Oscuro */
}

/* Etiquetas de sección ("Cuentas guardadas", "Contraseña") */
.section-label {
    -fx-font-size: 14px;
    -fx-font-weight: bold;
    -fx-text-fill: #1E3A5F;
}

/* Texto general (por si lo usas) */
.label {
    -fx-text-fill: #1E3A5F;
}

/* Mensajes de estado */
.status-label {
    -fx-text-fill: #0891B2; /* Azul Tecnológico */
    -fx-font-size: 11px;
}

/* -------------------------
   Botones
   ------------------------- */

.button {
    -fx-background-radius: 8;
    -fx-padding: 6 14 6 14;
    -fx-background-color: #0891B2; /* Azul Tecnológico */
    -fx-text-fill: white;
    -fx-font-weight: bold;
}

.button:hover {
    -fx-background-color: #06B6D4; /* Cyan Brillante */
}

.button:pressed {
    -fx-background-color: #1E3A5F; /* Azul Corporativo Oscuro */
}

/* Botón toggle tema Claro/Oscuro */
.toggle-button {
    -fx-background-radius: 999;
    -fx-background-color: #B8BEC4; /* Gris Metálico */
    -fx-text-fill: #1E3A5F;
}

.toggle-button:selected {
    -fx-background-color: #0891B2; /* Azul Tecnológico */
    -fx-text-fill: white;
}

/* -------------------------
   Campos de texto
   ------------------------- */

.text-field,
.password-field {
    -fx-background-color: white;
    -fx-background-radius: 6;
    -fx-border-radius: 6;
    -fx-border-color: #B8BEC4; /* Gris Metálico */
    -fx-border-width: 1;
    -fx-text-fill: #1E3A5F;
}

.text-field:focused,
.password-field:focused {
    -fx-border-color: #06B6D4; /* Cyan Brillante */
    -fx-border-width: 2;
}

/* -------------------------
   Tarjetas cuentas (login)
   ------------------------- */

.account-card {
    -fx-padding: 10;
    -fx-background-radius: 12;
    -fx-background-color: #E8ECEF; /* Plata Claro */
    -fx-border-color: #B8BEC4;     /* Gris Metálico */
    -fx-border-radius: 12;
    -fx-border-width: 1;
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
    -fx-cursor: hand;
}

.account-card:hover {
    -fx-background-color: #06B6D4; /* Cyan Brillante */
}

.account-card-selected {
    -fx-background-color: #0891B2; /* Azul Tecnológico */
    -fx-border-color: #1E3A5F;
}

.account-email {
    -fx-font-weight: bold;
    -fx-text-fill: #1E3A5F;
}

.account-server {
    -fx-font-size: 11px;
    -fx-text-fill: #4b5563; /* gris más oscuro */
}

/* Tarjeta "+ Añadir cuenta" */
.account-card-new {
    -fx-padding: 10;
    -fx-background-radius: 12;
    -fx-background-color: #B8BEC4; /* Gris Metálico */
    -fx-border-radius: 12;
    -fx-border-color: #0891B2;     /* Azul Tecnológico */
    -fx-border-width: 1;
    -fx-cursor: hand;
}

.account-card-new:hover {
    -fx-background-color: #06B6D4; /* Cyan Brillante */
}

.account-new-label {
    -fx-font-weight: bold;
    -fx-text-fill: #1E3A5F;
}
/* Fondo transparente para el scroll de cuentas en tema claro */
.accounts-scroll {
    -fx-background-color: transparent;
    -fx-background-insets: 0;
    -fx-padding: 0;
}

.accounts-scroll > .viewport {
    -fx-background-color: transparent;
}

#accountsList {
    -fx-background-color: transparent;
}

