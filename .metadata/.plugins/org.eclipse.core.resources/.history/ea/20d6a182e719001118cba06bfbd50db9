@import "styles-basic.css";

/* Fondo general + texto */
.root {
    -fx-background-color: #0F172A;
    -fx-text-fill: #F1F5F9;
}

/* Título */
.title-label {
    -fx-text-fill: #38BDF8;
}

/* Secciones y secundario */
.section-label {
    -fx-text-fill: #F1F5F9;
}

.label-secondary,
.status-label {
    -fx-text-fill: #94A3B8;
}

/* Botones */
.button {
    -fx-background-color: #22D3EE;
    -fx-text-fill: #0F172A;
    -fx-font-weight: bold;
}

.button:hover {
    -fx-background-color: #67E8F9;
}

.button:pressed {
    -fx-background-color: #38BDF8;
}

.toggle-button {
    -fx-background-color: #334155;
    -fx-text-fill: #F1F5F9;
}

.toggle-button:selected {
    -fx-background-color: #22D3EE;
    -fx-text-fill: #0F172A;
}

/* Campos */
.text-field,
.password-field,
.text-area {
    -fx-background-color: #1E293B;
    -fx-border-color: #334155;
    -fx-text-fill: #F1F5F9;
}

/* Tarjetas cuentas */
.account-card {
    -fx-background-color: #1E293B;
    -fx-border-color: #334155;
}

.account-card-selected {
    -fx-background-color: #38BDF8;
    -fx-border-color: #00F0FF;
}

.account-card-new {
    -fx-background-color: #0F172A;
    -fx-border-color: #22D3EE;
}

.account-email {
    -fx-text-fill: #F1F5F9;
}

.account-server {
    -fx-text-fill: #94A3B8;
}

/* Lista mensajes */
.list-view .message-card {
    -fx-background-color: #1E293B;
}

.list-view .message-card:selected {
    -fx-background-color: #38BDF8;
    -fx-text-fill: #0F172A;
}

/* Chips IA */
.chip {
    -fx-background-color: #22D3EE;
    -fx-text-fill: #0F172A;
}

/* Panel IA */
.ia-panel {
    -fx-background-color: #1E293B;
}

/* Sidebar */
.sidebar {
    -fx-background-color: #020617;
}

.sidebar-toggle {
    -fx-background-color: #1E293B;
    -fx-text-fill: #F1F5F9;
}

.sidebar-toggle:selected {
    -fx-background-color: #38BDF8;
    -fx-text-fill: #0F172A;
}
