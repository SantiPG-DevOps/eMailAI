<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21.0.1"
            fx:controller="com.emailAI.controller.CorreoController">

    <!-- BARRA SUPERIOR: acciones generales -->
    <top>
        <HBox spacing="8" styleClass="top-bar">
            <padding>
                <Insets bottom="8" left="10" right="10" top="8" />
            </padding>

            <Button onAction="#onRedactar" text="Redactar" />

            <Button onAction="#onResponder" text="Responder" />
            <Button onAction="#onResponderTodos" text="Responder a todos" />
            <Button onAction="#onReenviar" text="Reenviar" />

            <!-- Separador flexible para empujar el estado a la derecha -->
            <Pane HBox.hgrow="ALWAYS" />

            <Label fx:id="lblEstado" styleClass="label-secondary" />
        </HBox>
    </top>

    <!-- CONTENIDO CENTRAL -->
    <center>
        <SplitPane dividerPositions="0.3">
            <items>
                <!-- Columna IZQUIERDA: bandeja de entrada -->
                <VBox prefWidth="340" spacing="5">
                    <padding>
                        <Insets bottom="10" left="10" right="5" top="10" />
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label styleClass="section-label" text="Bandeja de entrada" />
                        <Button fx:id="btnActualizar"
                                onAction="#onActualizarBandeja"
                                styleClass="small-button"
                                text="Enviar/Recibir" />
                    </HBox>

                    <!-- Lista de mensajes (tarjetas) -->
                    <ListView fx:id="lstMensajes" VBox.vgrow="ALWAYS" />
                </VBox>

                <!-- Columna DERECHA: detalle + acciones + IA -->
                <VBox spacing="8">
                    <padding>
                        <Insets bottom="10" left="5" right="10" top="10" />
                    </padding>

                    <!-- Cabecera del mensaje + acciones -->
                    <HBox spacing="10">
                        <!-- Bloque asunto + remitente ocupa el espacio sobrante -->
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label fx:id="lblAsunto" styleClass="message-subject" />
                            <Label fx:id="lblRemitente" styleClass="label-secondary" />
                        </VBox>

                        <!-- Acciones sobre el mensaje actual (fijas) -->
                        <HBox alignment="CENTER_RIGHT" spacing="6">
                            <Button fx:id="btnReentrenar"
                                    onAction="#onReentrenarModelo"
                                    text="Act IA"
                                    styleClass="action-button" />
                            <Button fx:id="btnSpam"
                                    onAction="#onMarcarSpam"
                                    text="SPAM"
                                    prefWidth="70"
                                    styleClass="action-button" />
                            <Button fx:id="btnLegitimo"
                                    onAction="#onMarcarLegitimo"
                                    text="Legit"
                                    prefWidth="70"
                                    styleClass="action-button" />
                        </HBox>
                    </HBox>

                    <!-- Cuerpo del mensaje: WebView + TextArea fallback -->
                    <VBox spacing="6" VBox.vgrow="ALWAYS">
                        <!-- Visor HTML -->
                        <WebView fx:id="webViewCuerpo"
                                 VBox.vgrow="ALWAYS" />

                        <!-- Fallback texto plano -->
                        <TextArea fx:id="txtCuerpo"
                                  editable="false"
                                  wrapText="true"
                                  prefRowCount="18"
                                  VBox.vgrow="ALWAYS"
                                  styleClass="text-area" />
                    </VBox>

                    <!-- Panel de respuestas IA -->
                    <VBox spacing="6" styleClass="ia-panel">
                        <Label styleClass="label-secondary"
                               text="Respuestas sugeridas por IA" />
                        <HBox spacing="8">
                            <Button fx:id="btnSug1"
                                    onAction="#onUsarRespuesta1"
                                    styleClass="chip"
                                    HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnSug2"
                                    onAction="#onUsarRespuesta2"
                                    styleClass="chip"
                                    HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnSug3"
                                    onAction="#onUsarRespuesta3"
                                    styleClass="chip"
                                    HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnAnularSub"
                                    text="Anular sub"
                                    onAction="#onAnularSub"
                                    styleClass="chip"
                                    HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                </VBox>
            </items>
        </SplitPane>
    </center>

</BorderPane>
