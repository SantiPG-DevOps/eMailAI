.root {
    -fx-background-color: #E8ECEF;
    -fx-base: #E8ECEF;
    -fx-text-fill: #1E3A5F;
    -fx-selection-bar: #0891B2;
    -fx-selection-bar-text: white;
}

.label { -fx-text-fill: #1E3A5F; }
.label-secondary { -fx-text-fill: #5C6B7A; }
.status-label { -fx-text-fill: #0891B2; }

.config-root,
.config-content-stack,
.main-background {
    -fx-background-color: #E8ECEF;
}

.sidebar,
.top-bar,
.ia-panel,
.card,
.config-section-box {
    -fx-background-color: #FFFFFF;
}

.config-header-wrap,
.config-footer-wrap,
.config-nav-pane,
.main-app-sidebar {
    -fx-background-color: #FFFFFF;
    -fx-border-color: #B8BEC4;
}

.config-screen-title,
.config-page-heading,
.config-section-kicker,
.config-field-label,
.config-nav-heading,
.section-label,
.title-label,
.message-subject,
.account-email,
.contact-name,
.contact-phone {
    -fx-text-fill: #1E3A5F;
}

.account-server,
.contact-email,
.main-nav-heading,
.main-nav-submenu-heading,
.chat-model-label,
.chat-typing-label {
    -fx-text-fill: #5C6B7A;
}

.text-field,
.password-field,
.text-area,
.combo-box,
.choice-box,
.spinner,
.list-view {
    -fx-background-color: white;
    -fx-control-inner-background: white;
    -fx-text-fill: #1E3A5F;
    -fx-prompt-text-fill: #5C6B7A;
    -fx-border-color: #B8BEC4;
}

.text-field:focused,
.password-field:focused,
.text-area:focused {
    -fx-border-color: #0891B2;
}

.button,
.button.config-primary-btn,
.btn-primary {
    -fx-background-color: #0891B2;
    -fx-text-fill: white;
}

.button.config-secondary-btn,
.btn-secondary,
.theme-toggle,
.sidebar-submenu-toggle,
.action-button,
.btn-pag {
    -fx-background-color: #FFFFFF;
    -fx-text-fill: #1E3A5F;
    -fx-border-color: #B8BEC4;
}

.config-nav-list .list-cell:filled:selected,
.config-nav-list .list-cell:filled:selected:focused,
.main-nav-folder-list .list-cell:filled:selected,
.main-nav-folder-list .list-cell:filled:selected:focused,
.toggle-button.main-nav-primary:selected {
    -fx-background-color: #0891B2;
    -fx-text-fill: white;
}

.chat-bubble-user {
    -fx-background-color: #0891B2;
    -fx-text-fill: white;
}

.chat-bubble-ia,
.chat-header,
.chat-input-bar {
    -fx-background-color: #FFFFFF;
    -fx-text-fill: #1E3A5F;
    -fx-border-color: #B8BEC4;
}

.config-header-accent {
    -fx-background-color: #0891B2;
}
