package com.emailAI.controller;

import com.emailAI.model.Tarea;

import javafx.fxml.FXML;
import javafx.scene.control.*;
import javafx.stage.Stage;

// Controlador del diálogo modal para crear o editar una tarea.
public class TareaDialogController {

    @FXML private TextField txtTitulo; // Campo del título de la tarea.
    @FXML private DatePicker dpFecha; // Selector de fecha de vencimiento.
    @FXML private ComboBox<String> cmbEstado; // Selector del estado de la tarea.
    @FXML private TextField txtEtiquetas; // Campo de etiquetas en texto plano.
    @FXML private TextArea txtDescripcion; // Descripción libre de la tarea.
    @FXML private Label lblEstado; // Mensaje de validación o estado del diálogo.

    private Stage stage; // Stage modal para poder cerrarlo desde el controlador.
    private Tarea tarea; // Instancia editada o nueva tarea creada en el diálogo.
    private boolean guardado = false; // Marca si el usuario guardó cambios.

    // Inyecta la ventana modal asociada para control de cierre.
    public void setStage(Stage stage) {
        this.stage = stage;
    }

    // Carga en el formulario los datos de una tarea existente o prepara una nueva.
    public void setTarea(Tarea tarea) {
        this.tarea = tarea;
        if (tarea != null) {
            txtTitulo.setText(tarea.getTitulo());
            dpFecha.setValue(tarea.getFechaVencimiento());
            cmbEstado.getSelectionModel().select(
                    tarea.getEstado() != null ? tarea.getEstado() : "PENDIENTE"
            );
            txtEtiquetas.setText(tarea.getEtiquetas());
            txtDescripcion.setText(tarea.getDescripcion());
        } else {
            cmbEstado.getSelectionModel().select("PENDIENTE");
        }
    }

    // Inicializa los estados permitidos en el ComboBox.
    public void inicializarEstados() {
        cmbEstado.getItems().setAll("PENDIENTE", "EN_PROGRESO", "COMPLETADA");
        if (cmbEstado.getSelectionModel().isEmpty()) {
            cmbEstado.getSelectionModel().select("PENDIENTE");
        }
    }

    // Indica si el diálogo terminó con guardado confirmado.
    public boolean isGuardado() {
        return guardado;
    }

    // Devuelve la tarea resultante tras cerrar el diálogo.
    public Tarea getTarea() {
        return tarea;
    }

    // Valida campos obligatorios y vuelca datos del formulario al modelo de tarea.
    @FXML
    private void onGuardar() {
        String titulo = txtTitulo.getText();
        if (titulo == null || titulo.isBlank()) {
            lblEstado.setText("El título es obligatorio.");
            return;
        }
        if (tarea == null) {
            tarea = new Tarea();
        }

        tarea.setTitulo(titulo.trim());
        tarea.setDescripcion(safe(txtDescripcion.getText()));
        tarea.setFechaVencimiento(dpFecha.getValue());
        tarea.setEstado(cmbEstado.getValue());
        tarea.setEtiquetas(safe(txtEtiquetas.getText()));

        guardado = true;
        if (stage != null) stage.close();
    }

    // Cierra el diálogo sin persistir cambios.
    @FXML
    private void onCancelar() {
        guardado = false;
        if (stage != null) stage.close();
    }

    // Normaliza cadenas nulas y elimina espacios laterales.
    private String safe(String s) {
        return s != null ? s.trim() : "";
    }
}