.root {
    -fx-font-family: "Segoe UI", "Roboto", "Sans-Serif";
}

/* Títulos y secciones */
.title-label {
    -fx-font-size: 26px;
    -fx-font-weight: bold;
}

.section-label {
    -fx-font-size: 14px;
    -fx-font-weight: bold;
}

/* Estado */
.status-label,
.label-secondary {
    -fx-font-size: 11px;
}

/* Botón pequeño */
.small-button {
    -fx-font-size: 11px;
    -fx-padding: 4 10 4 10;
}

/* Tarjetas de cuentas (genérico) */
.account-card {
    -fx-padding: 10;
    -fx-background-radius: 12;
    -fx-border-radius: 12;
    -fx-border-width: 1;
    -fx-cursor: hand;
}

.account-card-selected {
    /* colores concretos se definen en dark/light */
}

.account-email {
    -fx-font-weight: bold;
}

.account-server {
    -fx-font-size: 11px;
}

/* Lista de mensajes como tarjetas */
.list-view .message-card {
    -fx-padding: 8;
    -fx-background-radius: 10;
}

.message-subject {
    -fx-font-size: 16px;
    -fx-font-weight: bold;
}

/* Tarjetas de contactos */
.contact-card {
    -fx-padding: 8 10 8 10;
    -fx-background-radius: 10;
    -fx-border-radius: 10;
    -fx-border-width: 1;
}

.list-cell.contact-card-cell {
    -fx-padding: 4 6 4 6;
    -fx-background-color: transparent;
}

.contact-name {
    -fx-font-weight: bold;
}

.contact-email {
    -fx-font-size: 11px;
    -fx-opacity: 0.85;
}

.contact-phone {
    -fx-font-weight: normal;
}

/* Chips IA */
.chip {
    -fx-background-radius: 999;
    -fx-padding: 4 12 4 12;
}

/* Panel IA */
.ia-panel {
    -fx-background-radius: 8;
    -fx-padding: 8 10 8 10;
}

/* Sidebar */
.sidebar {
    -fx-padding: 10 5 10 5;
    -fx-spacing: 10;
}

.sidebar-toggle {
    -fx-background-radius: 999;
    -fx-padding: 6 14 6 14;
}

/* Barra superior correo */
.top-bar {
    -fx-spacing: 8;
}

/* LOGIN: campos y botón principal */
.login-password {
    /* hereda de .text-field; ajusta aquí si quieres algo específico */
}

.primary-button {
    -fx-font-size: 14px;
    -fx-font-weight: bold;
    -fx-padding: 10 14 10 14;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
}

/* Toggle sol/luna */
.theme-toggle {
    -fx-font-size: 14px;
    -fx-background-radius: 999;
    -fx-border-radius: 999;
    -fx-padding: 4 10 4 10;
}

/* Calendario */
.cal-dia {
    -fx-border-color: #cccccc;
    -fx-border-radius: 6;
    -fx-background-radius: 6;
    -fx-padding: 6;
    -fx-alignment: top-left;
    -fx-min-height: 40;
}

.cal-dia-hoy {
    -fx-border-color: #0078d7;
    -fx-background-color: #e4f1ff;
}

.cal-dia-seleccionado {
    -fx-background-color: #d0eaff;
}