<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.emailAI.controller.LoginController"
            prefWidth="800" prefHeight="600">

    <!-- CONTENIDO CENTRADO -->
    <center>
        <VBox alignment="CENTER" spacing="24">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <!-- Título + logo -->
            <VBox alignment="CENTER" spacing="8">
                <Label text="eMailAI"
                       styleClass="title-label"/>

                <ImageView fx:id="logoImage"
                           fitHeight="80"
                           preserveRatio="true"/>
            </VBox>

            <!-- Cuentas guardadas -->
            <VBox spacing="6" prefWidth="500">
                <!-- Fila: título izq + botón der -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Cuentas guardadas"
                           styleClass="section-label"/>

                    <Pane HBox.hgrow="ALWAYS"/>

                    <Button text="+ Añadir cuenta"
                            fx:id="newAccountButton"
                            onAction="#onNewAccountClicked"
                            styleClass="small-button"/>
                </HBox>

                <ScrollPane fitToWidth="true" prefViewportHeight="220">
                    <content>
                        <TilePane fx:id="accountsTilePane"
                                  hgap="10" vgap="10"
                                  prefColumns="2"
                                  prefTileWidth="220"
                                  prefTileHeight="70"/>
                    </content>
                </ScrollPane>
            </VBox>

            <!-- Contraseña + botón Entrar -->
            <VBox spacing="8" prefWidth="360">
                <Label text="Contraseña"
                       styleClass="section-label"/>

                <PasswordField fx:id="passwordField"
                               promptText="Introduce la contraseña"
                               styleClass="text-field login-password"/>

                <Button text="Entrar"
                        fx:id="loginButton"
                        onAction="#onLoginClicked"
                        defaultButton="true"
                        prefWidth="360"
                        styleClass="primary-button"/>

                <Label fx:id="statusLabel"
                       text=""
                       styleClass="status-label"/>
            </VBox>
        </VBox>
    </center>

    <!-- ABAJO: toggle de tema centrado -->
    <bottom>
        <HBox alignment="CENTER" spacing="10">
            <padding>
                <Insets top="10" right="20" bottom="20" left="20"/>
            </padding>

            <ToggleButton fx:id="themeToggle"
                          onAction="#onThemeToggle"
                          styleClass="theme-toggle"/>
        </HBox>
    </bottom>

</BorderPane>
