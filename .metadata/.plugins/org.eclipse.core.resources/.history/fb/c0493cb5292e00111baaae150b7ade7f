<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.emailAI.controller.ContactosController">

    <center>
        <SplitPane dividerPositions="0.35">
            <items>

                <!-- IZQUIERDA: lista de contactos -->
                <VBox spacing="8" minWidth="260">
                    <padding>
                        <Insets top="10" left="10" right="5" bottom="10"/>
                    </padding>

                    <HBox spacing="6">
                        <Label text="Contactos" styleClass="section-label" VBox.vgrow="NEVER"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button text="Nuevo" onAction="#onNuevoContacto" styleClass="small-button"/>
                        <Button text="Borrar" onAction="#onBorrarContacto" styleClass="small-button"/>
                    </HBox>

                    <ListView fx:id="lstContactos" VBox.vgrow="ALWAYS"/>
                </VBox>

                <!-- DERECHA: formulario detalle -->
                <VBox spacing="8" minWidth="340">
                    <padding>
                        <Insets top="10" left="5" right="10" bottom="10"/>
                    </padding>

                    <GridPane hgap="8" vgap="8">
                        <columnConstraints>
                            <ColumnConstraints minWidth="80"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <children>
                            <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtEmail" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Teléfono:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtTelefono" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Notas:" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
                            <TextArea fx:id="txtNotas"
                                      GridPane.rowIndex="3"
                                      GridPane.columnIndex="1"
                                      prefRowCount="5"
                                      wrapText="true"/>
                        </children>
                    </GridPane>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="lblEstado" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="Guardar" onAction="#onGuardarContacto" defaultButton="true"/>
                    </HBox>
                </VBox>

            </items>
        </SplitPane>
    </center>

</BorderPane>