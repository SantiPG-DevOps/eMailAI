<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.emailAI.controller.ComposeController">

    <top>
        <GridPane hgap="5" vgap="5">
            <columnConstraints>
                <ColumnConstraints prefWidth="60"/>
                <ColumnConstraints prefWidth="400"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints/>
                <RowConstraints/>
                <RowConstraints/>
            </rowConstraints>

            <children>
                <Label text="Para:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtPara" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Asunto:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtAsunto" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Button text="Enviar" onAction="#onEnviar"
                        GridPane.rowIndex="2" GridPane.columnIndex="1"
                        GridPane.halignment="RIGHT"/>
            </children>
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
        </GridPane>
    </top>

    <center>
        <TextArea fx:id="txtCuerpo" wrapText="true"/>
    </center>

    <bottom>
        <Label fx:id="lblEstado" />
    </bottom>

</BorderPane>
