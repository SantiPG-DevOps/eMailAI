package com.emailAI.controller;

import com.emailAI.dao.DAOCuentas;
import com.emailAI.security.UtilidadCifrado;
import javafx.fxml.FXML;
import javafx.scene.control.*;
import javafx.scene.layout.VBox;
import javafx.stage.Stage;

public class NuevaCuentaController {

    @FXML
    private TextField txtEmail;

    @FXML
    private PasswordField txtPassword;

    @FXML
    private ComboBox<String> cmbProveedor;

    @FXML
    private VBox boxPersonalizado;

    @FXML
    private TextField txtImap;

    @FXML
    private TextField txtSmtp;

    @FXML
    private void initialize() {
        // seleccionar valor por defecto (Gmail si existe en el combo)
        if (cmbProveedor.getItems().contains("Gmail")) {
            cmbProveedor.getSelectionModel().select("Gmail");
        } else if (!cmbProveedor.getItems().isEmpty()) {
            cmbProveedor.getSelectionModel().select(0);
        }

        actualizarServidorSegunProveedor();

        cmbProveedor.getSelectionModel()
                .selectedItemProperty()
                .addListener((obs, oldV, newV) -> actualizarServidorSegunProveedor());
    }

    private void actualizarServidorSegunProveedor() {
        String proveedor = cmbProveedor.getSelectionModel().getSelectedItem();
        if (proveedor == null) {
            proveedor = "";
        }

        switch (proveedor) {
            case "Gmail":
                txtImap.setText("imap.gmail.com");          // [web:104]
                txtSmtp.setText("smtp.gmail.com");          // [web:104]
                boxPersonalizado.setVisible(false);
                boxPersonalizado.setManaged(false);
                break;
            case "Outlook.com / Office 365":
                txtImap.setText("imap-mail.outlook.com");   // [web:105]
                txtSmtp.setText("smtp-mail.outlook.com");   // [web:105]
                boxPersonalizado.setVisible(false);
                boxPersonalizado.setManaged(false);
                break;
            case "Yahoo Mail":
                txtImap.setText("imap.mail.yahoo.com");     // [web:106]
                txtSmtp.setText("smtp.mail.yahoo.com");     // [web:106]
                boxPersonalizado.setVisible(false);
                boxPersonalizado.setManaged(false);
                break;
            case "Personalizado":
            default:
                boxPersonalizado.setVisible(true);
                boxPersonalizado.setManaged(true);
                // no tocamos txtImap/txtSmtp para permitir que el usuario escriba
                break;
        }
    }

    @FXML
    private void onGuardar() {
        String email = txtEmail.getText();
        String password = txtPassword.getText();
        String imap = txtImap.getText();
        String smtp = txtSmtp.getText();

        if (email == null || email.isBlank()
                || password == null || password.isBlank()
                || imap == null || imap.isBlank()
                || smtp == null || smtp.isBlank()) {
            mostrarAlerta("Campos incompletos",
                    "Rellena email, contraseña, IMAP y SMTP.");
            return;
        }

        try {
            // email con clave fija de app
            String emailCifrado = UtilidadCifrado.cifrar(email);
            // hash de la contraseña maestra (la misma que usarás en el login)
            String passHash = UtilidadCifrado.hash(password);

            DAOCuentas dao = new DAOCuentas();
            dao.guardarCuenta(imap, smtp, emailCifrado, passHash);

            cerrarVentana();
        } catch (Exception e) {
            e.printStackTrace();
            mostrarAlerta("Error al guardar", e.getMessage());
        }
    }

    @FXML
    private void onCancelar() {
        cerrarVentana();
    }

    private void cerrarVentana() {
        Stage stage = (Stage) txtEmail.getScene().getWindow();
        stage.close();
    }

    private void mostrarAlerta(String titulo, String mensaje) {
        Alert alert = new Alert(Alert.AlertType.ERROR);
        alert.setTitle("Nueva cuenta");
        alert.setHeaderText(titulo);
        alert.setContentText(mensaje);
        alert.showAndWait();
    }
}
