package com.emailAI.service;

import com.emailAI.model.ThemePreset;

public class ThemeCssResolver {

    public String getThemeCssPath(ThemePreset theme, String mode) {
        String folder = "/themes/";
        String suffix = "dark".equalsIgnoreCase(mode) ? "-dark.css" : "-light.css";

        return switch (theme) {
            case OCEAN_TEAL -> folder + "ocean-teal" + suffix;
            case GRAPHITE_MINT -> folder + "graphite-mint" + suffix;
            case AMBER_SLATE -> folder + "amber-slate" + suffix;
            case INDIGO_MIST -> folder + "indigo-mist" + suffix;
            case EMERALD_PAPER -> folder + "emerald-paper" + suffix;
            case RUBY_INK -> folder + "ruby-ink" + suffix;
            case VIOLET_SMOKE -> folder + "violet-smoke" + suffix;
            case SLATE_GOLD -> folder + "slate-gold" + suffix;
            case ARCTIC_BLUE -> folder + "arctic-blue" + suffix;
            case SAND_CORAL -> folder + "sand-coral" + suffix;
            case FOREST_STONE -> folder + "forest-stone" + suffix;
            case MIDNIGHT_ROSE -> folder + "midnight-rose" + suffix;
            case NEUTRAL_CYAN -> folder + "neutral-cyan" + suffix;
            case WARM_BEIGE_TEAL -> folder + "warm-beige-teal" + suffix;
            case DEEP_NAVY_LIME -> folder + "deep-navy-lime" + suffix;
        };
    }
}