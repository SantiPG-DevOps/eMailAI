package com.emailAI.controller;

import com.emailAI.dao.DAOContactos;
import com.emailAI.model.Contacto;
import javafx.collections.FXCollections;
import javafx.collections.ObservableList;
import javafx.fxml.FXML;
import javafx.fxml.FXMLLoader;
import javafx.scene.Parent;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.layout.HBox;
import javafx.scene.layout.Priority;
import javafx.scene.layout.VBox;
import javafx.stage.Modality;

import java.util.ArrayList;
import java.util.List;

public class ContactosController {

    @FXML private ListView<Contacto> lstCol1;
    @FXML private ListView<Contacto> lstCol2;
    @FXML private ListView<Contacto> lstCol3;
    @FXML private Label lblEstado;
    @FXML private Button btnEditar;
    @FXML private Button btnBorrar;

    private DAOContactos daoContactos;
    private final ObservableList<Contacto> todos = FXCollections.observableArrayList();
    private Contacto contactoSeleccionado;

    @FXML
    private void initialize() {
        daoContactos = new DAOContactos("jdbc:sqlite:emailAI.db");

        configurarLista(lstCol1);
        configurarLista(lstCol2);
        configurarLista(lstCol3);

        cargarContactos();
    }

    // Configura cell factory y listener de selección en una columna
    private void configurarLista(ListView<Contacto> lista) {
        lista.setCellFactory(lv -> new ListCell<>() {
            @Override
            protected void updateItem(Contacto c, boolean empty) {
                super.updateItem(c, empty);
                if (empty || c == null) {
                    setText(null);
                    setGraphic(null);
                    getStyleClass().removeAll("contact-card-cell");
                    return;
                }

                HBox root = new HBox(10);
                root.getStyleClass().add("contact-card");
                root.setPickOnBounds(false);

                VBox leftBox = new VBox(2);
                Label lblNombre = new Label(c.getNombre() != null ? c.getNombre() : "");
                lblNombre.getStyleClass().add("contact-name");
                leftBox.getChildren().add(lblNombre);

                String email = c.getEmail() != null ? c.getEmail() : "";
                if (!email.isBlank()) {
                    Label lblEmail = new Label(email);
                    lblEmail.getStyleClass().add("contact-email");
                    leftBox.getChildren().add(lblEmail);
                }

                Label lblTelefono = new Label(c.getTelefono() != null ? c.getTelefono() : "");
                lblTelefono.getStyleClass().add("contact-phone");

                HBox.setHgrow(leftBox, Priority.ALWAYS);
                root.getChildren().addAll(leftBox, lblTelefono);

                setText(null);
                setGraphic(root);
                getStyleClass().removeAll("contact-card-cell");
                getStyleClass().add("contact-card-cell");
            }
        });

        // Al seleccionar en esta columna, deselecciona las otras
        lista.getSelectionModel().selectedItemProperty().addListener((obs, old, sel) -> {
            if (sel == null) return;
            contactoSeleccionado = sel;
            // Deselecciona las otras dos columnas sin disparar el listener de nuevo
            deselectOtras(lista);
            actualizarBotones();
            lblEstado.setText("");
        });
    }

    // Deselecciona las otras dos listas sin perder la selección actual
    private void deselectOtras(ListView<Contacto> activa) {
        if (activa != lstCol1) lstCol1.getSelectionModel().clearSelection();
        if (activa != lstCol2) lstCol2.getSelectionModel().clearSelection();
        if (activa != lstCol3) lstCol3.getSelectionModel().clearSelection();
    }

    private void actualizarBotones() {
        boolean hay = contactoSeleccionado != null;
        if (btnEditar != null) btnEditar.setDisable(!hay);
        if (btnBorrar != null) btnBorrar.setDisable(!hay);
    }

    // Distribuye los contactos en 3 columnas: 0→col1, 1→col2, 2→col3, 3→col1...
    private void distribuirEnColumnas() {
        List<Contacto> c1 = new ArrayList<>();
        List<Contacto> c2 = new ArrayList<>();
        List<Contacto> c3 = new ArrayList<>();

        for (int i = 0; i < todos.size(); i++) {
            switch (i % 3) {
                case 0 -> c1.add(todos.get(i));
                case 1 -> c2.add(todos.get(i));
                case 2 -> c3.add(todos.get(i));
            }
        }

        lstCol1.setItems(FXCollections.observableArrayList(c1));
        lstCol2.setItems(FXCollections.observableArrayList(c2));
        lstCol3.setItems(FXCollections.observableArrayList(c3));
    }

    private void cargarContactos() {
        todos.setAll(daoContactos.listarTodos());
        contactoSeleccionado = null;
        actualizarBotones();
        distribuirEnColumnas();
    }

    @FXML
    private void onNuevoContacto() {
        abrirDialogoEdicion(null);
    }

    @FXML
    private void onEditarContacto() {
        if (contactoSeleccionado == null) {
            lblEstado.setText("Selecciona un contacto para editar.");
            return;
        }
        abrirDialogoEdicion(contactoSeleccionado);
    }

    @FXML
    private void onBorrarContacto() {
        if (contactoSeleccionado == null) {
            lblEstado.setText("Selecciona un contacto para borrar.");
            return;
        }

        Alert confirm = new Alert(Alert.AlertType.CONFIRMATION);
        confirm.setTitle("Borrar contacto");
        confirm.setHeaderText("¿Borrar \"" + contactoSeleccionado.getNombre() + "\"?");
        confirm.setContentText("Esta acción no se puede deshacer.");
        var res = confirm.showAndWait();
        if (res.isEmpty() || res.get() != ButtonType.OK) return;

        daoContactos.borrar(contactoSeleccionado);
        contactoSeleccionado = null;
        actualizarBotones();
        cargarContactos();
        lblEstado.setText("Contacto borrado.");
    }

    // Abre el diálogo de edición/creación. Si contacto es null → modo nuevo.
    private void abrirDialogoEdicion(Contacto contacto) {
        try {
            // Usamos un Dialog inline con un GridPane — sin FXML extra
            Dialog<ButtonType> dialog = new Dialog<>();
            dialog.setTitle(contacto == null ? "Nuevo contacto" : "Editar contacto");
            dialog.initModality(Modality.APPLICATION_MODAL);

            // Formulario
            javafx.scene.layout.GridPane grid = new javafx.scene.layout.GridPane();
            grid.setHgap(10);
            grid.setVgap(10);
            grid.setPadding(new javafx.geometry.Insets(16, 20, 12, 20));

            javafx.scene.layout.ColumnConstraints col0 = new javafx.scene.layout.ColumnConstraints();
            col0.setMinWidth(80);
            javafx.scene.layout.ColumnConstraints col1 = new javafx.scene.layout.ColumnConstraints();
            col1.setHgrow(javafx.scene.layout.Priority.ALWAYS);
            col1.setMinWidth(220);
            grid.getColumnConstraints().addAll(col0, col1);

            TextField fNombre   = new TextField(contacto != null ? safe(contacto.getNombre())   : "");
            TextField fEmail    = new TextField(contacto != null ? safe(contacto.getEmail())    : "");
            TextField fTelefono = new TextField(contacto != null ? safe(contacto.getTelefono()) : "");
            TextArea  fNotas    = new TextArea (contacto != null ? safe(contacto.getNotas())    : "");
            fNotas.setPrefRowCount(4);
            fNotas.setWrapText(true);

            fNombre.setPromptText("Nombre completo");
            fEmail.setPromptText("correo@ejemplo.com");
            fTelefono.setPromptText("+34 600 000 000");
            fNotas.setPromptText("Notas opcionales");

            grid.add(new Label("Nombre:"),   0, 0); grid.add(fNombre,   1, 0);
            grid.add(new Label("Email:"),    0, 1); grid.add(fEmail,    1, 1);
            grid.add(new Label("Teléfono:"), 0, 2); grid.add(fTelefono, 1, 2);
            Label lblNotas = new Label("Notas:");
            javafx.scene.layout.GridPane.setValignment(lblNotas, javafx.geometry.VPos.TOP);
            grid.add(lblNotas, 0, 3); grid.add(fNotas, 1, 3);

            dialog.getDialogPane().setContent(grid);
            dialog.getDialogPane().getButtonTypes().setAll(ButtonType.CANCEL, ButtonType.OK);

            // Aplica estilos de la escena principal
            if (lstCol1.getScene() != null) {
                dialog.getDialogPane().getStylesheets()
                      .setAll(lstCol1.getScene().getStylesheets());
            }

            // Validación al pulsar OK
            Button okBtn = (Button) dialog.getDialogPane().lookupButton(ButtonType.OK);
            okBtn.addEventFilter(javafx.event.ActionEvent.ACTION, ev -> {
                if (fNombre.getText().isBlank()) {
                    ev.consume();
                    lblEstado.setText("El nombre es obligatorio.");
                }
            });

            var res = dialog.showAndWait();
            if (res.isEmpty() || res.get() != ButtonType.OK) return;

            if (contacto == null) {
                Contacto nuevo = new Contacto(null,
                        fNombre.getText().trim(),
                        safe(fEmail.getText()),
                        safe(fTelefono.getText()),
                        safe(fNotas.getText()));
                daoContactos.guardarOActualizar(nuevo);
                lblEstado.setText("Contacto creado.");
            } else {
                contacto.setNombre(fNombre.getText().trim());
                contacto.setEmail(safe(fEmail.getText()));
                contacto.setTelefono(safe(fTelefono.getText()));
                contacto.setNotas(safe(fNotas.getText()));
                daoContactos.guardarOActualizar(contacto);
                lblEstado.setText("Contacto actualizado.");
            }

            cargarContactos();

        } catch (Exception e) {
            e.printStackTrace();
            lblEstado.setText("Error: " + e.getMessage());
        }
    }

    private String safe(String s) {
        return s != null ? s.trim() : "";
    }
}