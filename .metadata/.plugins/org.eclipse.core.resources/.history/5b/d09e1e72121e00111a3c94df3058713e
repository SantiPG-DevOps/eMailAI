<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.emailAI.controller.LoginController"
            prefWidth="420" prefHeight="360">

    <!-- ZONA SUPERIOR: título + logo -->
    <top>
        <VBox alignment="CENTER" spacing="6">
            <padding>
                <Insets top="16" right="20" bottom="8" left="20"/>
            </padding>

            <Label text="eMailAI"
                   styleClass="title-label"/>

            <ImageView fx:id="logoImage"
                       fitHeight="70"
                       preserveRatio="true"/>
        </VBox>
    </top>

    <!-- ZONA CENTRAL: cuentas + contraseña + botón -->
    <center>
        <VBox spacing="14" alignment="CENTER">
            <padding>
                <Insets top="10" right="40" bottom="10" left="40"/>
            </padding>

            <!-- Cuentas guardadas -->
            <VBox spacing="4" prefWidth="320">
                <Label text="Cuentas guardadas"
                       styleClass="section-label"/>

                <ComboBox fx:id="accountsCombo"
                          styleClass="login-combo"
                          prefWidth="320"
                          promptText="Selecciona una cuenta"/>
            </VBox>

            <!-- Contraseña + botón Entrar -->
            <VBox spacing="6" prefWidth="320">
                <Label text="Contraseña"
                       styleClass="section-label"/>

                <PasswordField fx:id="passwordField"
                               promptText="Introduce la contraseña"
                               styleClass="text-field login-password"/>

                <Button text="Entrar"
                        fx:id="loginButton"
                        onAction="#onLoginClicked"
                        defaultButton="true"
                        prefWidth="320"
                        styleClass="primary-button"/>

                <!-- Mensajes de error/estado -->
                <Label fx:id="statusLabel"
                       text=""
                       styleClass="status-label"/>
            </VBox>
        </VBox>
    </center>

    <!-- ZONA INFERIOR: tema + configuración -->
    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <ToggleButton fx:id="themeToggle"
                          text="Claro / Oscuro"
                          onAction="#onThemeToggle"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button text="Nueva cuenta"
                    fx:id="newAccountButton"
                    onAction="#onNewAccountClicked"/>

            <Button text="Configuración"
                    fx:id="settingsButton"
                    onAction="#onSettingsClicked"
                    styleClass="flat-button"/>
        </HBox>
    </bottom>

</BorderPane>
