@import "styles-basic.css";

/* Fondo general */
.root {
    -fx-background-color: #0F172A;
    -fx-text-fill: #F1F5F9;
}

/* Títulos */
.title-label {
    -fx-text-fill: #38BDF8;
}

.section-label {
    -fx-text-fill: #F1F5F9;
}

.label-secondary,
.status-label {
    -fx-text-fill: #94A3B8;
}

/* Botones */
.button {
    -fx-background-radius: 8;
    -fx-padding: 6 14 6 14;
    -fx-background-color: #22D3EE;
    -fx-text-fill: #0F172A;
    -fx-font-weight: bold;
}

.button:hover {
    -fx-background-color: #67E8F9;
}

.button:pressed {
    -fx-background-color: #38BDF8;
}

/* Toggle */
.toggle-button {
    -fx-background-radius: 999;
    -fx-background-color: #334155;
    -fx-text-fill: #F1F5F9;
}

.toggle-button:selected {
    -fx-background-color: #22D3EE;
    -fx-text-fill: #0F172A;
}

/* Campos */
.text-field,
.password-field,
.text-area {
    -fx-background-color: #1E293B;
    -fx-background-radius: 6;
    -fx-border-radius: 6;
    -fx-border-color: #334155;
    -fx-border-width: 1;
    -fx-text-fill: #F1F5F9;
}

.text-field:focused,
.password-field:focused,
.text-area:focused {
    -fx-border-color: #22D3EE;
    -fx-border-width: 2;
}

/* Tarjetas cuentas */
.account-card {
    -fx-background-color: #1E293B;
    -fx-border-color: #334155;
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 12, 0, 0, 4);
}

.account-card:hover {
    -fx-background-color: #334155;
}

.account-card-selected {
    -fx-background-color: #38BDF8;
    -fx-border-color: #00F0FF;
}

.account-card-new {
    -fx-background-color: #0F172A;
    -fx-border-color: #22D3EE;
}

.account-email {
    -fx-text-fill: #F1F5F9;
}

.account-server {
    -fx-text-fill: #94A3B8;
}

/* Lista mensajes */
.list-view {
    -fx-background-color: #0F172A;
    -fx-control-inner-background: #0F172A;
    -fx-background-insets: 0;
    -fx-padding: 4;
}

.list-view .message-card {
    -fx-background-color: #1E293B;
}

.list-view .message-card:selected {
    -fx-background-color: #38BDF8;
    -fx-text-fill: #0F172A;
}

/* Panel IA */
.ia-panel {
    -fx-background-color: #1E293B;
}

/* Sidebar */
.sidebar {
    -fx-background-color: #020617;
}

.sidebar-toggle {
    -fx-background-color: #1E293B;
    -fx-text-fill: #F1F5F9;
}

.sidebar-toggle:selected {
    -fx-background-color: #38BDF8;
    -fx-text-fill: #0F172A;
}
/* =========================
   eMailAI - MODO OSCURO
   Paleta de Santiago
   ========================= */

/* Fondo principal de la app */
.root {
    -fx-background-color: #0F172A;      /* Fondo Principal */
    -fx-base: #0F172A;
    -fx-text-fill: #F1F5F9;             /* Texto Principal */
    -fx-font-family: "Segoe UI", "Roboto", "Sans-Serif";
}

/* ========= CONTENEDORES Y PANELES ========= */

/* Panel principal / fondo de cada vista */
.main-background {
    -fx-background-color: #0F172A;
}

/* Menú lateral (Correo, Calendario, etc.) */
.sidebar {
    -fx-background-color: #1E293B;      /* Fondo Secundario */
}

/* Tarjetas, bloques de contenido (login, panel derecho, etc.) */
.card {
    -fx-background-color: #1E293B;      /* Fondo Secundario */
    -fx-background-radius: 12;
    -fx-border-radius: 12;
    -fx-border-color: #334155;          /* Fondo Elevado como borde */
    -fx-border-width: 1;
}

/* Panel más elevado (opcional) */
.elevated {
    -fx-background-color: #334155;      /* Fondo Elevado */
    -fx-background-radius: 16;
}

/* ========= TEXTOS ========= */

.label {
    -fx-text-fill: #F1F5F9;             /* Texto Principal */
}

.label-title {
    -fx-text-fill: #38BDF8;             /* Azul Corporativo brillante */
    -fx-font-size: 20px;
    -fx-font-weight: bold;
}

.label-subtitle {
    -fx-text-fill: #94A3B8;             /* Texto Secundario */
    -fx-font-size: 13px;
}

/* Texto de estados (ej: “Bandeja actualizada”) */
.status-label {
    -fx-text-fill: #22D3EE;             /* Cyan Tecnológico */
    -fx-font-size: 12px;
}

/* ========= CAMPOS DE TEXTO ========= */

.text-field {
    -fx-background-color: #0F172A;
    -fx-control-inner-background: #0F172A;
    -fx-text-fill: #F1F5F9;
    -fx-prompt-text-fill: #94A3B8;
    -fx-border-color: #334155;
    -fx-border-radius: 8;
    -fx-background-radius: 8;
}

.text-field:focused {
    -fx-border-color: #22D3EE;
}

/* Área de texto del cuerpo del correo */
.text-area {
    -fx-control-inner-background: #0F172A;  /* Fondo Principal */
    -fx-background-color: #1E293B;         /* Marco */
    -fx-text-fill: #F1F5F9;
    -fx-border-color: #334155;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
}

/* ========= LISTA DE MENSAJES ========= */

.list-view {
    -fx-background-color: #0F172A;
    -fx-control-inner-background: #1E293B;  /* Fondo Secundario */
    -fx-text-fill: #F1F5F9;
    -fx-padding: 4;
}

/* Celda estándar para mensajes (la que creas con styleClass "message-card") */
.list-cell.message-card {
    -fx-background-color: #1E293B;         /* Fondo Secundario */
    -fx-text-fill: #F1F5F9;
    -fx-padding: 6 10 6 10;
}

/* Celdas vacías sin color raro */
.list-cell:empty {
    -fx-background-color: transparent;
}

/* Mensaje seleccionado: alto contraste */
.list-cell.message-card:selected {
    -fx-background-color: #38BDF8;         /* Azul Corporativo */
    -fx-text-fill: #0F172A;                /* Texto oscuro sobre azul claro */
}

/* Pie o separador en la lista (ej. “20 anuncios nuevos”), si lo usas */
.list-cell.message-card.footer {
    -fx-background-color: #334155;         /* Fondo Elevado */
    -fx-text-fill: #F1F5F9;
}

/* ========= BOTONES ========= */

/* Botones principales (Entrar, Enviar/Recibir, Redactar, etc.) */
.button {
    -fx-background-color: #22D3EE;         /* Cyan Tecnológico */
    -fx-text-fill: #0F172A;
    -fx-font-weight: bold;
    -fx-background-radius: 20;
    -fx-border-radius: 20;
    -fx-border-color: transparent;
}

.button:hover {
    -fx-background-color: #67E8F9;         /* Cyan Brillante */
}

/* Botones secundarios (si les pones styleClass="secondary") */
.button.secondary {
    -fx-background-color: #1E293B;         /* Fondo Secundario */
    -fx-text-fill: #F1F5F9;
    -fx-border-color: #38BDF8;
    -fx-border-width: 1;
}

.button.secondary:hover {
    -fx-background-color: #334155;         /* Fondo Elevado */
}

/* Botones de respuestas IA (barra inferior) */
.button.ia {
    -fx-background-color: #22D3EE;         /* Cyan Tecnológico */
    -fx-text-fill: #0F172A;
    -fx-font-weight: bold;
    -fx-background-radius: 20;
}

.button.ia:hover {
    -fx-background-color: #67E8F9;         /* Cyan Brillante */
}

/* Botón “Claro / Oscuro” si lo quieres distinto */
.button.theme-toggle {
    -fx-background-color: #1E293B;
    -fx-text-fill: #F1F5F9;
    -fx-border-color: #22D3EE;
    -fx-border-width: 1;
}
.button.theme-toggle:hover {
    -fx-background-color: #334155;
}

/* ========= SCROLLBARS ========= */

.scroll-bar:vertical,
.scroll-bar:horizontal {
    -fx-background-color: transparent;
}

.scroll-bar .thumb {
    -fx-background-color: #334155;
    -fx-background-radius: 5;
}

.scroll-bar .thumb:hover {
    -fx-background-color: #38BDF8;
}

/* ========= OTROS ========= */

/* Tabs (si usas TabPane en otras vistas) */
.tab-pane {
    -fx-background-color: #0F172A;
}

.tab {
    -fx-background-color: #1E293B;
    -fx-text-base-color: #F1F5F9;
}

.tab:selected {
    -fx-background-color: #38BDF8;
    -fx-text-base-color: #0F172A;
}

/* Efecto glow IA (puedes aplicarlo a algún icono o label con esta clase) */
.glow-ia {
    -fx-effect: dropshadow(gaussian, #00F0FF, 20, 0.5, 0, 0);
}
