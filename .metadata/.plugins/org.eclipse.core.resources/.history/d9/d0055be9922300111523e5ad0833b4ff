package com.emailAI.controller;

import com.emailAI.AppFX;
import com.emailAI.dao.DAOContactos;
import com.emailAI.dao.DAOTareas;
import com.emailAI.service.MailService;
import javafx.event.ActionEvent;
import javafx.fxml.FXML;
import javafx.fxml.FXMLLoader;
import javafx.scene.Node;
import javafx.scene.Scene;
import javafx.scene.control.ToggleButton;
import javafx.scene.layout.BorderPane;
import javafx.scene.layout.StackPane;
import javafx.stage.Stage;

public class MainController {

    @FXML
    private BorderPane rootPane;

    @FXML
    private StackPane centerPane;

    @FXML
    private ToggleButton btnBandeja;

    @FXML
    private ToggleButton btnTareas;

    @FXML
    private ToggleButton btnContactos;

    @FXML
    private ToggleButton themeToggle;

    // clave derivada de password+email que nos pasa LoginController
    private String claveCifrado;

    // id de la cuenta actual (DAOCuentas.CuentaGuardada.id)
    private int cuentaActualId;

    // estado actual del tema
    private boolean temaClaro = false;

    @FXML
    private void initialize() {
        // tema por defecto: oscuro
        temaClaro = false;
        if (themeToggle != null) {
            themeToggle.setSelected(temaClaro);
            themeToggle.setText("🌙");
        }
        // aplicamos tema a la escena cuando esté disponible
        if (rootPane != null && rootPane.getScene() != null) {
            setTemaClaro(temaClaro);
        } else {
            // si todavía no hay escena, se aplicará cuando se llame a setTemaClaro desde fuera
        }

        // vista por defecto: mail-view
        cargarVistaBandeja();
        if (btnBandeja != null) btnBandeja.setSelected(true);
    }

    // llamado desde LoginController tras login correcto
    public void setMailService(MailService mailService) {
    }

    // llamado desde LoginController: clave cifrado por cuenta + id
    public void setupCuenta(String claveCifrado, int cuentaId) {
        this.claveCifrado = claveCifrado;
        this.cuentaActualId = cuentaId;
    }

    // ===== Tema claro/oscuro usado por ConfigController =====

    public boolean isTemaClaro() {
        return temaClaro;
    }

    public void setTemaClaro(boolean claro) {
        this.temaClaro = claro;

        Scene scene = rootPane != null ? rootPane.getScene() : null;
        if (scene != null) {
            scene.getStylesheets().clear();
            scene.getStylesheets().add(
                    AppFX.class.getResource("/styles-basic.css").toExternalForm()
            );
            if (claro) {
                scene.getStylesheets().add(
                        AppFX.class.getResource("/styles-light.css").toExternalForm()
                );
            } else {
                scene.getStylesheets().add(
                        AppFX.class.getResource("/styles-dark.css").toExternalForm()
                );
            }
        }

        if (themeToggle != null) {
            themeToggle.setSelected(claro);
            themeToggle.setText(claro ? "☀" : "🌙");
        }
    }

    // --------- Navegación secciones ---------

    @FXML
    private void onSeccionBandeja(ActionEvent event) {
        cargarVistaBandeja();
        if (btnBandeja != null) {
            btnBandeja.setSelected(true);
            if (btnTareas != null) btnTareas.setSelected(false);
            if (btnContactos != null) btnContactos.setSelected(false);
        }
    }
    
    @FXML
    private void onSeccionCalendario(ActionEvent event) {
        // De momento, reutilizamos la bandeja o ponemos un placeholder
        // cargarVistaBandeja();
        javafx.scene.control.Label placeholder =
                new javafx.scene.control.Label("Calendario (pendiente de implementar)");
        centerPane.getChildren().setAll(placeholder);
    }

    // alias para el handler antiguo del FXML
    @FXML
    private void onSeccionCorreo(ActionEvent event) {
        onSeccionBandeja(event);
    }

    @FXML
    private void onSeccionTareas(ActionEvent event) {
        cargarVistaTareas();
        if (btnTareas != null) {
            btnTareas.setSelected(true);
            if (btnBandeja != null) btnBandeja.setSelected(false);
            if (btnContactos != null) btnContactos.setSelected(false);
        }
    }

    @FXML
    private void onSeccionContactos(ActionEvent event) {
        cargarVistaContactos();
        if (btnContactos != null) {
            btnContactos.setSelected(true);
            if (btnBandeja != null) btnBandeja.setSelected(false);
            if (btnTareas != null) btnTareas.setSelected(false);
        }
    }

    private void cargarVistaBandeja() {
        try {
            FXMLLoader loader = new FXMLLoader(AppFX.class.getResource("/ui/mail-view.fxml"));
            Node vista = loader.load();

            MailViewController controller = loader.getController();
            if (controller != null) {
                // contenido de prueba por ahora
                controller.mostrarMensaje(
                        "Remitente de prueba <test@example.com>",
                        "Bienvenido a eMailAI",
                        "<html><body style='font-family:sans-serif;font-size:13px;'>"
                                + "<h2>Hola, Santiago 👋</h2>"
                                + "<p>Esta es la vista HTML del mensaje. "
                                + "Pronto cargaremos aquí correos reales desde el servidor IMAP.</p>"
                                + "</body></html>"
                );
            }

            centerPane.getChildren().setAll(vista);
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    private void cargarVistaTareas() {
        try {
            FXMLLoader loader = new FXMLLoader(AppFX.class.getResource("/ui/tareas-view.fxml"));
            Node vista = loader.load();

            TareasController controller = loader.getController();
            if (controller != null && claveCifrado != null && cuentaActualId > 0) {
                DAOTareas dao = new DAOTareas(claveCifrado);
                controller.configurar(dao, cuentaActualId);
            }

            centerPane.getChildren().setAll(vista);
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    private void cargarVistaContactos() {
        try {
            FXMLLoader loader = new FXMLLoader(AppFX.class.getResource("/ui/contactos-view.fxml"));
            Node vista = loader.load();

            ContactosController controller = loader.getController();
            if (controller != null && claveCifrado != null && cuentaActualId > 0) {
                DAOContactos dao = new DAOContactos(claveCifrado);
                controller.configurar(dao, cuentaActualId);
            }

            centerPane.getChildren().setAll(vista);
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    // --------- Tema claro/oscuro desde el toggle ---------

    @FXML
    private void onThemeToggle(ActionEvent event) {
        if (themeToggle != null) {
            setTemaClaro(themeToggle.isSelected());
        }
    }

    // --------- Logout / volver al login ---------

    @FXML
    private void onLogout(ActionEvent event) {
        try {
            FXMLLoader loader = new FXMLLoader(AppFX.class.getResource("/ui/login-view.fxml"));
            Scene loginScene = new Scene(loader.load());

            // aplicar tema actual también al login
            Scene oldScene = rootPane.getScene();
            if (oldScene != null) {
                loginScene.getStylesheets().clear();
                loginScene.getStylesheets().addAll(oldScene.getStylesheets());
            }

            Stage stage = (Stage) rootPane.getScene().getWindow();
            stage.setTitle("eMailAI - Login");
            stage.setScene(loginScene);
            stage.show();
        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}
