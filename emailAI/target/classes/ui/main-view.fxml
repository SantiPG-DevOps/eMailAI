<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.emailAI.controller.MainController"
            fx:id="rootPane">

    <fx:define>
        <ToggleGroup fx:id="grpSecciones"/>
    </fx:define>

    <left>
        <VBox styleClass="main-app-sidebar"
              minWidth="200"
              prefWidth="232"
              maxWidth="280"
              spacing="0">

            <padding>
                <Insets top="14" right="10" bottom="14" left="10"/>
            </padding>

            <VBox spacing="10" maxWidth="Infinity">
                <ImageView fx:id="imgLogo"
                           fitWidth="168.0"
                           preserveRatio="true"
                           pickOnBounds="true"
                           styleClass="main-sidebar-logo">
                    <image>
                        <Image url="@../logo.png"/>
                    </image>
                </ImageView>
                <Label text="eMailAI" styleClass="main-sidebar-brand"/>
            </VBox>

            <Label text="Menú" styleClass="main-nav-heading">
                <VBox.margin>
                    <Insets top="14" bottom="6" left="4"/>
                </VBox.margin>
            </Label>

            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        maxHeight="Infinity"
                        VBox.vgrow="ALWAYS"
                        styleClass="main-sidebar-scroll">
                <VBox spacing="6" maxWidth="Infinity">
                    <padding>
                        <Insets bottom="8"/>
                    </padding>

                    <ToggleButton text="Correo" fx:id="btnCorreo"
                                  toggleGroup="$grpSecciones"
                                  onAction="#onSeccionCorreo"
                                  maxWidth="Infinity"
                                  styleClass="main-nav-primary"/>

                    <VBox fx:id="vboxSubmenuCorreo"
                          spacing="4"
                          visible="false"
                          managed="false"
                          maxWidth="Infinity"
                          styleClass="main-nav-submenu">
                        <padding>
                            <Insets left="12" right="0" top="2" bottom="4"/>
                        </padding>
                        <Label text="Carpetas" styleClass="main-nav-submenu-heading"/>
                        <ListView fx:id="listaCarpetasImap"
                                  prefHeight="200"
                                  minHeight="96"
                                  maxHeight="320"
                                  maxWidth="Infinity"
                                  styleClass="main-nav-folder-list"/>
                    </VBox>

                    <ToggleButton text="Calendario" fx:id="btnCalendario"
                                  toggleGroup="$grpSecciones"
                                  onAction="#onSeccionCalendario"
                                  maxWidth="Infinity"
                                  styleClass="main-nav-primary"/>

                    <ToggleButton text="Contactos" fx:id="btnContactos"
                                  toggleGroup="$grpSecciones"
                                  onAction="#onSeccionContactos"
                                  maxWidth="Infinity"
                                  styleClass="main-nav-primary"/>

                    <ToggleButton text="Tareas" fx:id="btnTareas"
                                  toggleGroup="$grpSecciones"
                                  onAction="#onSeccionTareas"
                                  maxWidth="Infinity"
                                  styleClass="main-nav-primary"/>
                </VBox>
            </ScrollPane>

            <Separator maxWidth="Infinity">
                <VBox.margin>
                    <Insets top="6" bottom="8"/>
                </VBox.margin>
            </Separator>

            <VBox spacing="6" maxWidth="Infinity">
                <ToggleButton text="Configuración" fx:id="btnConfiguracion"
                              toggleGroup="$grpSecciones"
                              onAction="#onSeccionConfiguracion"
                              maxWidth="Infinity"
                              styleClass="main-nav-primary"/>

                <ToggleButton text="Chat IA" fx:id="btnChatIA"
                              toggleGroup="$grpSecciones"
                              onAction="#onSeccionChatIA"
                              maxWidth="Infinity"
                              styleClass="main-nav-primary"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="centerPane"/>
    </center>

</BorderPane>
