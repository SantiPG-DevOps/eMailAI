<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.emailAI.controller.ContactosController">

    <center>
        <VBox spacing="8">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <children>
                <Label text="Contactos" styleClass="section-label"/>

                <ListView fx:id="lstContactos" VBox.vgrow="ALWAYS"/>

                <HBox spacing="6">
                    <Button text="Añadir" onAction="#onAgregarContacto" styleClass="small-button"/>
                    <Button text="Eliminar" onAction="#onEliminarContacto" styleClass="small-button"/>
                </HBox>

                <Separator/>

                <GridPane hgap="6" vgap="6">
                    <columnConstraints>
                        <ColumnConstraints minWidth="80"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <children>
                        <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtEmail" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Teléfono:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtTelefono" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Notas:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <TextArea fx:id="txtNotas" GridPane.rowIndex="3" GridPane.columnIndex="1" prefRowCount="3"/>
                    </children>
                </GridPane>
            </children>
        </VBox>
    </center>

</BorderPane>
