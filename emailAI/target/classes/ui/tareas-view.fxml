<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.emailAI.controller.TareasController">

    <top>
        <HBox spacing="8">
            <padding>
                <Insets top="12" right="12" bottom="6" left="12"/>
            </padding>
            <children>
                <Label text="Bandeja de tareas" styleClass="title-label"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="8">
            <padding>
                <Insets top="6" right="12" bottom="12" left="12"/>
            </padding>
            <children>
                <ListView fx:id="lstTareas" VBox.vgrow="ALWAYS"/>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="8">
            <padding>
                <Insets top="8" right="12" bottom="8" left="12"/>
            </padding>
            <children>
                <TextField fx:id="txtNuevaTarea" HBox.hgrow="ALWAYS"
                           promptText="Añadir tarea..."/>
                <DatePicker fx:id="dpFechaLimite"/>
                <Button text="Añadir" onAction="#onAgregarTarea" styleClass="small-button"/>
                <Button text="Completar" onAction="#onCompletarTarea" styleClass="small-button"/>
                <Button text="Eliminar" onAction="#onEliminarTarea" styleClass="small-button"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>
