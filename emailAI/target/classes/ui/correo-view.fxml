<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.emailAI.controller.CorreoController">

    <top>
        <Pane />
    </top>

    <center>
        <!-- SplitPane con tamaños mínimos -->
        <SplitPane dividerPositions="0.3">
            <items>

                <!-- Columna IZQUIERDA: Redactar + bandeja de entrada -->
                <VBox prefWidth="340" minWidth="260" spacing="8">
                    <padding>
                        <Insets bottom="10" left="10" right="5" top="10" />
                    </padding>

                    <!-- Fila: Redactar + Borrar -->
                    <HBox prefHeight="31.0" spacing="6">
                        <children>
                            <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <children>
                                    <Button onAction="#onRedactar" text="Redactar" />
                                </children>
                            </HBox>

                            <!-- Relleno -->
                            <Pane HBox.hgrow="ALWAYS"/>

                            <!-- Borrar pegado a la derecha -->
                            <HBox alignment="CENTER_RIGHT">
                                <children>
                                    <Button fx:id="btnBorrarSeleccionado"
                                            onAction="#onBorrarMensajeSeleccionado"
                                            text="Borrar" />
                                </children>
                            </HBox>
                        </children>
                    </HBox>

                    <!-- Fila: Bandeja + Enviar/Recibir -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <children>
                            <Label styleClass="section-label"
                                   text="Bandeja de entrada"
                                   HBox.hgrow="ALWAYS" />

                            <!-- Relleno -->
                            <Pane HBox.hgrow="ALWAYS"/>

                            <!-- Enviar/Recibir pegado a la derecha -->
                            <Button fx:id="btnActualizar"
                                    onAction="#onActualizarBandeja"
                                    styleClass="small-button"
                                    text="Enviar/Recibir" />
                        </children>
                    </HBox>

                    <ListView fx:id="lstMensajes" VBox.vgrow="ALWAYS" />
                </VBox>

                <!-- Columna DERECHA: barra de acciones + detalle + IA -->
                <VBox spacing="8" minWidth="400">
                    <padding>
                        <Insets bottom="10" left="5" right="10" top="10" />
                    </padding>

                    <!-- Barra de acciones: Responder... a la izq, IA a la dcha -->
                    <HBox spacing="6">
                        <!-- Acciones de correo -->
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <children>
                                <Button onAction="#onResponder" text="Responder" />
                                <Button onAction="#onResponderTodos" text="Responder a todos" />
                                <Button onAction="#onReenviar" text="Reenviar" />
                            </children>
                        </HBox>

                        <!-- Relleno que empuja a la derecha -->
                        <Pane HBox.hgrow="ALWAYS" />

                        <!-- Acciones IA alineadas a la derecha -->
                        <HBox alignment="CENTER_RIGHT" spacing="6">
                            <children>
                                <Button fx:id="btnReentrenar"
                                        onAction="#onReentrenarModelo"
                                        styleClass="action-button"
                                        text="Act IA" />
                                <Button fx:id="btnSpam"
                                        onAction="#onMarcarSpam"
                                        prefWidth="70"
                                        styleClass="action-button"
                                        text="SPAM" />
                                <Button fx:id="btnLegitimo"
                                        onAction="#onMarcarLegitimo"
                                        prefWidth="70"
                                        styleClass="action-button"
                                        text="Legit" />
                            </children>
                        </HBox>
                    </HBox>

                    <!-- Cabecera del mensaje: asunto + remitente -->
                    <VBox spacing="3">
                        <Label fx:id="lblAsunto" styleClass="message-subject" />
                        <Label fx:id="lblRemitente" styleClass="label-secondary" />
                    </VBox>

                    <!-- Cuerpo del mensaje -->
                    <VBox spacing="6" VBox.vgrow="ALWAYS">
                        <WebView fx:id="webViewCuerpo" VBox.vgrow="ALWAYS" />
                        <TextArea fx:id="txtCuerpo"
                                  editable="false"
                                  prefRowCount="18"
                                  styleClass="text-area"
                                  wrapText="true"
                                  VBox.vgrow="ALWAYS" />
                    </VBox>

                    <!-- Panel de respuestas IA -->
                    <VBox spacing="6" styleClass="ia-panel">
                        <Label styleClass="label-secondary" text="Respuestas sugeridas por IA" />
                        <HBox spacing="8">
                            <Button fx:id="btnSug1" onAction="#onUsarRespuesta1" styleClass="chip" HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnSug2" onAction="#onUsarRespuesta2" styleClass="chip" HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnSug3" onAction="#onUsarRespuesta3" styleClass="chip" HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnAnularSub" onAction="#onAnularSub" styleClass="chip" text="Anular sub" HBox.hgrow="ALWAYS" />
                            <Button text="Permitir imágenes" fx:id="btnPermitirImagenes" onAction="#onPermitirImagenes" styleClass="small-button"/>
                        </HBox>
                    </VBox>

                </VBox>
            </items>
        </SplitPane>
    </center>

    <!-- Barra de estado inferior: mitad app / mitad IA -->
    <bottom>
        <HBox spacing="10" styleClass="status-bar" prefHeight="24">
            <padding>
                <Insets left="8" right="8" top="2" bottom="2"/>
            </padding>

            <!-- Estado app -->
            <Label fx:id="lblEstadoApp"
                   text=""
                   maxWidth="Infinity"
                   HBox.hgrow="ALWAYS"
                   styleClass="status-label"/>

            <!-- Separador visual opcional -->
            <Label text="|" styleClass="status-separator"/>

            <!-- Estado IA -->
            <Label fx:id="lblEstadoIA"
                   text="IA: esperando interacción"
                   maxWidth="Infinity"
                   HBox.hgrow="ALWAYS"
                   styleClass="status-label-right"/>
        </HBox>
    </bottom>

</BorderPane>