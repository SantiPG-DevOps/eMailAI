<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.emailAI.controller.NuevaCuentaController"
      spacing="10">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <children>
        <Label text="Configurar nueva cuenta" styleClass="title-label"/>

        <TextField fx:id="servidorImapField"
                   promptText="Servidor IMAP (ej: imap.gmx.com)"/>

        <TextField fx:id="servidorSmtpField"
                   promptText="Servidor SMTP (ej: smtp.gmx.com)"/>

        <TextField fx:id="emailField"
                   promptText="Correo electrónico"/>

        <PasswordField fx:id="passCorreoField"
                       promptText="Contraseña del correo"/>

        <PasswordField fx:id="passMaestraField"
                       promptText="Contraseña maestra (para abrir la app)"/>

        <PasswordField fx:id="passMaestraRepeatField"
                       promptText="Repite contraseña maestra"/>

        <Label fx:id="statusLabel" text="" styleClass="status-label"/>

        <HBox spacing="10">
            <children>
                <Button text="Cancelar" onAction="#onCancelar"/>
                <Button text="Guardar cuenta" onAction="#onGuardarClicked"/>
            </children>
        </HBox>
    </children>
</VBox>
