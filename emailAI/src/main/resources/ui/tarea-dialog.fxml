<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.emailAI.controller.TareaDialogController">

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="10" left="10" right="10" bottom="10"/>
            </padding>

            <GridPane hgap="8" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="80"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <children>
                    <Label text="Título:"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTitulo"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Fecha:"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="dpFecha"
                                GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Estado:"
                           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbEstado" maxWidth="Infinity"
                              GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Prioridad:"
                           GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbPrioridad" maxWidth="Infinity"
                              GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Etiquetas:"
                           GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtEtiquetas"
                               GridPane.rowIndex="4" GridPane.columnIndex="1"
                               promptText="ej. trabajo,personal,urgente"/>

                    <Label text="Descripción:"
                           GridPane.rowIndex="5" GridPane.columnIndex="0"
                           GridPane.valignment="TOP"/>
                    <TextArea fx:id="txtDescripcion"
                              GridPane.rowIndex="5" GridPane.columnIndex="1"
                              prefRowCount="6" wrapText="true"/>
                </children>
            </GridPane>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <children>
                    <Label fx:id="lblEstado" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="Cancelar" onAction="#onCancelar"/>
                    <Button text="Guardar"  onAction="#onGuardar" defaultButton="true"/>
                </children>
            </HBox>
        </VBox>
    </center>

</BorderPane>