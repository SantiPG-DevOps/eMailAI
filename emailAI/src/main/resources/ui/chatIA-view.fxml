<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.emailAI.controller.ChatIAController"
      spacing="0" styleClass="chat-root">

    <!-- Cabecera -->
    <HBox styleClass="chat-header" spacing="10" alignment="CENTER_LEFT">
        <Label text="Chat IA" styleClass="chat-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblModelo" text="Modelo: —" styleClass="chat-model-label"/>
        <Button fx:id="btnLimpiar" text="Limpiar" onAction="#onLimpiarChat"
                styleClass="btn-ghost"/>
    </HBox>

    <!-- Historial de mensajes -->
    <ScrollPane fx:id="scrollChat" fitToWidth="true"
                VBox.vgrow="ALWAYS" styleClass="chat-scroll">
        <VBox fx:id="vboxMensajes" styleClass="chat-messages" spacing="8"/>
    </ScrollPane>

    <!-- Indicador de escritura -->
    <HBox fx:id="hboxEscribiendo" styleClass="chat-typing" spacing="6"
          alignment="CENTER_LEFT" managed="false" visible="false">
        <ProgressIndicator prefWidth="16" prefHeight="16"/>
        <Label text="La IA está respondiendo…" styleClass="chat-typing-label"/>
    </HBox>

    <!-- Input -->
    <HBox styleClass="chat-input-bar" spacing="8" alignment="CENTER">
        <TextArea fx:id="txtInput" promptText="Escribe tu pregunta sobre los correos…"
                  wrapText="true" prefRowCount="2"
                  HBox.hgrow="ALWAYS" styleClass="chat-input"/>
        <Button fx:id="btnEnviar" text="Enviar" onAction="#onEnviar"
                defaultButton="true" styleClass="btn-primary"/>
    </HBox>

</VBox>