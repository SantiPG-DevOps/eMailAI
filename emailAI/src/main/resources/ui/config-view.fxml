<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.emailAI.controller.ConfigController"
            styleClass="config-root"
            maxWidth="Infinity"
            maxHeight="Infinity">

    <fx:define>
        <ToggleGroup fx:id="themeGroup"/>
    </fx:define>

    <top>
        <VBox spacing="0" styleClass="config-header-wrap">
            <padding>
                <Insets top="18" right="20" bottom="14" left="20"/>
            </padding>
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Region styleClass="config-header-accent"
                        minWidth="5" prefWidth="5" minHeight="52" maxHeight="Infinity"/>
                <VBox alignment="CENTER_LEFT" spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Ajustes" styleClass="config-screen-title"/>
                    <Label text="Personaliza la apariencia, las cuentas de correo y las integraciones."
                           styleClass="label-secondary"
                           wrapText="true"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.26"
                   maxHeight="Infinity"
                   maxWidth="Infinity"
                   styleClass="config-split">
            <items>

                <!-- Navegación lateral -->
                <VBox spacing="0"
                      styleClass="config-nav-pane"
                      minWidth="168"
                      prefWidth="200"
                      maxWidth="260">
                    <padding>
                        <Insets top="12" right="8" bottom="12" left="12"/>
                    </padding>
                    <Label text="Categorías" styleClass="config-nav-heading"/>
                    <ListView fx:id="configNavList"
                              VBox.vgrow="ALWAYS"
                              styleClass="config-nav-list"/>
                </VBox>

                <!-- Páginas -->
                <StackPane fx:id="configStack"
                           maxHeight="Infinity"
                           maxWidth="Infinity"
                           styleClass="config-content-stack">

                    <!-- 0: General -->
                    <ScrollPane fitToWidth="true"
                                hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED"
                                styleClass="config-scroll"
                                maxHeight="Infinity"
                                maxWidth="Infinity">
                        <content>
                            <VBox spacing="18" styleClass="config-tab-inner">
                                <padding>
                                    <Insets top="20" right="24" bottom="32" left="20"/>
                                </padding>

                                <Label text="Apariencia" styleClass="config-page-heading"/>

                                <VBox styleClass="config-section-box" spacing="12">
                                    <Label text="Tema de la aplicación" styleClass="config-section-kicker"/>
                                    <Label text="El cambio se aplica al momento en toda la aplicación. El estilo base se mantiene y solo cambian los colores."
                                           styleClass="label-secondary"
                                           wrapText="true"/>

                                    <Separator styleClass="config-sep"/>

                                    <HBox spacing="14" alignment="CENTER_LEFT">
                                        <Label text="Tema" styleClass="config-field-label" minWidth="88"/>
                                        <ComboBox fx:id="comboTema"
                                                  onAction="#onTemaSeleccionado"
                                                  prefWidth="240"/>
                                    </HBox>

                                    <HBox spacing="14" alignment="CENTER_LEFT">
                                        <Label text="Modo" styleClass="config-field-label" minWidth="88"/>
                                        <RadioButton fx:id="rbTemaClaro"
                                                     text="Claro"
                                                     toggleGroup="$themeGroup"
                                                     onAction="#onTemaClaro"/>
                                        <RadioButton fx:id="rbTemaOscuro"
                                                     text="Oscuro"
                                                     toggleGroup="$themeGroup"
                                                     onAction="#onTemaOscuro"/>
                                    </HBox>

                                    <VBox fx:id="boxTemaPersonalizado"
                                          spacing="12"
                                          visible="false"
                                          managed="false"
                                          styleClass="config-section-box">

                                        <Separator styleClass="config-sep"/>

                                        <Label text="Colores personalizados" styleClass="config-section-kicker"/>
                                        <Label text="Usa formato hexadecimal #RRGGBB, por ejemplo #1E293B."
                                               styleClass="label-secondary"
                                               wrapText="true"/>

                                        <GridPane hgap="14" vgap="12" styleClass="config-form-grid">
                                            <columnConstraints>
                                                <ColumnConstraints halignment="RIGHT" minWidth="148" prefWidth="156"/>
                                                <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                                            </columnConstraints>

                                            <Label text="Fondo" styleClass="config-field-label"
                                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                            <TextField fx:id="txtColorBg"
                                                       promptText="#0F172A"
                                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                            <Label text="Superficie" styleClass="config-field-label"
                                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                            <TextField fx:id="txtColorSurface"
                                                       promptText="#1E293B"
                                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                            <Label text="Texto principal" styleClass="config-field-label"
                                                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                            <TextField fx:id="txtColorText"
                                                       promptText="#F1F5F9"
                                                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                            <Label text="Texto secundario" styleClass="config-field-label"
                                                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                            <TextField fx:id="txtColorMuted"
                                                       promptText="#94A3B8"
                                                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                            <Label text="Primario" styleClass="config-field-label"
                                                   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                            <TextField fx:id="txtColorPrimary"
                                                       promptText="#22D3EE"
                                                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                                            <Label text="Borde" styleClass="config-field-label"
                                                   GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                            <TextField fx:id="txtColorBorder"
                                                       promptText="#334155"
                                                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                                        </GridPane>

                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <Button text="Aplicar personalizado"
                                                    onAction="#onAplicarTemaPersonalizado"
                                                    styleClass="config-primary-btn"/>
                                            <Label fx:id="lblTemaPersonalizadoEstado"
                                                   text=""
                                                   styleClass="label-secondary"
                                                   wrapText="true"/>
                                        </HBox>
                                    </VBox>
                                </VBox>
                            </VBox>
                        </content>
                    </ScrollPane>

                    <!-- 1: Correo -->
                    <ScrollPane fitToWidth="true"
                                hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED"
                                styleClass="config-scroll"
                                maxHeight="Infinity"
                                maxWidth="Infinity"
                                visible="false"
                                managed="false">
                        <content>
                            <VBox spacing="18" styleClass="config-tab-inner">
                                <padding>
                                    <Insets top="20" right="24" bottom="32" left="20"/>
                                </padding>

                                <Label text="Correo" styleClass="config-page-heading"/>

                                <VBox styleClass="config-section-box" spacing="12">
                                    <Label text="Cuentas en este equipo" styleClass="config-section-kicker"/>
                                    <Label text="Olvidar solo quita la cuenta de esta app; no borra mensajes en el servidor."
                                           styleClass="label-secondary"
                                           wrapText="true"/>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <ComboBox fx:id="comboCuentasExistentes"
                                                  promptText="Selecciona una cuenta…"
                                                  HBox.hgrow="ALWAYS"/>
                                        <Button text="Olvidar"
                                                onAction="#onOlvidarCuentaClicked"
                                                styleClass="config-secondary-btn"/>
                                    </HBox>
                                </VBox>

                                <VBox styleClass="config-section-box" spacing="14">
                                    <Label text="Añadir cuenta" styleClass="config-section-kicker"/>
                                    <Label text="Los datos se guardan cifrados en la base de datos local. Usa una contraseña maestra fuerte."
                                           styleClass="label-secondary"
                                           wrapText="true"/>

                                    <GridPane hgap="14" vgap="12" styleClass="config-form-grid">
                                        <columnConstraints>
                                            <ColumnConstraints halignment="RIGHT" minWidth="148" prefWidth="156"/>
                                            <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                                        </columnConstraints>

                                        <Label text="Proveedor"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="0"/>
                                        <ComboBox fx:id="providerCombo"
                                                  maxWidth="Infinity"
                                                  onAction="#onProviderChanged"
                                                  GridPane.rowIndex="0"
                                                  GridPane.columnIndex="1"/>

                                        <Label text="Correo"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="1"
                                               GridPane.columnIndex="0"/>
                                        <TextField fx:id="emailField"
                                                   promptText="usuario@dominio.com"
                                                   GridPane.rowIndex="1"
                                                   GridPane.columnIndex="1"/>

                                        <Label text="Contraseña maestra"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="2"
                                               GridPane.columnIndex="0"/>
                                        <PasswordField fx:id="masterPassField"
                                                       promptText="Protege el acceso local"
                                                       GridPane.rowIndex="2"
                                                       GridPane.columnIndex="1"/>

                                        <Label fx:id="imapLabel"
                                               text="IMAP"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="3"
                                               GridPane.columnIndex="0"/>
                                        <TextField fx:id="imapField"
                                                   promptText="imap.ejemplo.com"
                                                   GridPane.rowIndex="3"
                                                   GridPane.columnIndex="1"/>

                                        <Label fx:id="smtpLabel"
                                               text="SMTP"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="4"
                                               GridPane.columnIndex="0"/>
                                        <TextField fx:id="smtpField"
                                                   promptText="smtp.ejemplo.com"
                                                   GridPane.rowIndex="4"
                                                   GridPane.columnIndex="1"/>
                                    </GridPane>

                                    <Label fx:id="statusLabel"
                                           text=""
                                           styleClass="status-label"
                                           wrapText="true"/>
                                </VBox>

                                <VBox styleClass="config-section-box" spacing="10">
                                    <Label text="Sincronización automática" styleClass="config-section-kicker"/>
                                    <Label text="La bandeja de entrada (INBOX) se sincroniza en segundo plano con el intervalo indicado. Los cambios se aplican al pulsar Aplicar."
                                           styleClass="label-secondary"
                                           wrapText="true"/>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <Label text="Cada (minutos)"
                                               styleClass="config-field-label"
                                               minWidth="120"/>
                                        <Spinner fx:id="spinnerSyncMinutos" prefWidth="100"/>
                                        <Button text="Aplicar intervalo"
                                                onAction="#onAplicarIntervaloSync"
                                                styleClass="config-secondary-btn"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </content>
                    </ScrollPane>

                    <!-- 2: Calendario y tareas -->
                    <ScrollPane fitToWidth="true"
                                hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED"
                                styleClass="config-scroll"
                                maxHeight="Infinity"
                                maxWidth="Infinity"
                                visible="false"
                                managed="false">
                        <content>
                            <VBox spacing="18" styleClass="config-tab-inner">
                                <padding>
                                    <Insets top="20" right="24" bottom="32" left="20"/>
                                </padding>

                                <Label text="Calendario y Tareas" styleClass="config-page-heading"/>

                                <!-- Configuración ICS -->
                                <VBox styleClass="config-section-box" spacing="12">
                                    <Label text="Importación/Exportación de calendario (.ics)" styleClass="config-section-kicker"/>
                                    <Label text="Importa eventos desde archivos .ics o exporta tu calendario local."
                                           styleClass="label-secondary"
                                           wrapText="true"/>

                                    <Separator styleClass="config-sep"/>

                                    <GridPane hgap="14" vgap="12" styleClass="config-form-grid">
                                        <columnConstraints>
                                            <ColumnConstraints halignment="RIGHT" minWidth="148" prefWidth="156"/>
                                            <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                                        </columnConstraints>

                                        <Label text="Habilitar ICS"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="0"/>
                                        <CheckBox fx:id="chkIcsEnabled"
                                                  GridPane.rowIndex="0"
                                                  GridPane.columnIndex="1"/>

                                        <Label text="Importar archivo .ics"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="1"
                                               GridPane.columnIndex="0"/>
                                        <HBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                            <TextField fx:id="txtIcsPath"
                                                      promptText="/ruta/al/calendario.ics"
                                                      HBox.hgrow="ALWAYS"/>
                                            <Button fx:id="btnSeleccionarIcs"
                                                    text="Seleccionar"
                                                    onAction="#onSeleccionarArchivoIcs"/>
                                            <Button fx:id="btnImportarIcs"
                                                    text="Importar"
                                                    onAction="#onImportarArchivoIcs"/>
                                        </HBox>

                                        <Label text="Exportar calendario"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="2"
                                               GridPane.columnIndex="0"/>
                                        <HBox spacing="8" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                            <TextField fx:id="txtExportPath"
                                                      promptText="/ruta/para/exportar.ics"
                                                      HBox.hgrow="ALWAYS"/>
                                            <Button fx:id="btnSeleccionarExport"
                                                    text="Seleccionar"
                                                    onAction="#onSeleccionarRutaExport"/>
                                            <Button fx:id="btnExportarIcs"
                                                    text="Exportar"
                                                    onAction="#onExportarCalendarioIcs"/>
                                        </HBox>

                                        <Label text="Última sincronización"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="3"
                                               GridPane.columnIndex="0"/>
                                        <Label fx:id="lblUltimaSyncIcs"
                                               styleClass="label-secondary"
                                               GridPane.rowIndex="3"
                                               GridPane.columnIndex="1"/>
                                    </GridPane>
                                </VBox>

                                <!-- Configuración Todoist -->
                                <VBox styleClass="config-section-box" spacing="12">
                                    <Label text="Sincronización con Todoist" styleClass="config-section-kicker"/>
                                    <Label text="Sincroniza tareas con Todoist como backup. Configura la API y el tiempo de actualización."
                                           styleClass="label-secondary"
                                           wrapText="true"/>

                                    <Separator styleClass="config-sep"/>

                                    <GridPane hgap="14" vgap="12" styleClass="config-form-grid">
                                        <columnConstraints>
                                            <ColumnConstraints halignment="RIGHT" minWidth="148" prefWidth="156"/>
                                            <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                                        </columnConstraints>

                                        <Label text="Habilitar Todoist"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="0"/>
                                        <CheckBox fx:id="chkTodoistEnabled"
                                                  GridPane.rowIndex="0"
                                                  GridPane.columnIndex="1"/>

                                        <Label text="API Key"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="1"
                                               GridPane.columnIndex="0"/>
                                        <HBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                            <TextField fx:id="txtTodoistApiKey"
                                                      promptText="Tu API Key de Todoist"
                                                      HBox.hgrow="ALWAYS"/>
                                            <Button fx:id="btnProbarTodoist"
                                                    text="Probar"
                                                    onAction="#onProbarTodoist"/>
                                        </HBox>

                                        <Label text="Tiempo de actualización"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="2"
                                               GridPane.columnIndex="0"/>
                                        <HBox spacing="8" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                            <Spinner fx:id="spinnerTodoistInterval"
                                                      prefWidth="120"
                                                      min="5"
                                                      max="120"
                                                      amountToStepBy="5"
                                                      initialValue="30"/>
                                            <Label text="minutos" styleClass="label-secondary"/>
                                            <Button fx:id="btnForzarSyncTodoist"
                                                    text="Sincronizar ahora"
                                                    onAction="#onForzarSincronizacionTodoist"/>
                                        </HBox>

                                        <Label text="Dirección de sincronización"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="3"
                                               GridPane.columnIndex="0"/>
                                        <VBox spacing="6" GridPane.rowIndex="3" GridPane.columnIndex="1">
                                            <RadioButton fx:id="rbSyncBidireccional"
                                                         text="Bidireccional (local ↔ Todoist)"
                                                         selected="true"/>
                                            <RadioButton fx:id="rbSyncSoloSubida"
                                                         text="Solo subir (local → Todoist)"/>
                                            <RadioButton fx:id="rbSyncSoloBajada"
                                                         text="Solo bajar (Todoist → local)"/>
                                        </VBox>

                                        <Label text="Última sincronización"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="4"
                                               GridPane.columnIndex="0"/>
                                        <Label fx:id="lblUltimaSyncTodoist"
                                               styleClass="label-secondary"
                                               GridPane.rowIndex="4"
                                               GridPane.columnIndex="1"/>

                                        <Label fx:id="lblCalendarioEstado"
                                               styleClass="label-secondary"
                                               wrapText="true"
                                               GridPane.rowIndex="5"
                                               GridPane.columnIndex="1"/>
                                    </GridPane>

                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <Button text="Guardar configuración"
                                                onAction="#onGuardarConfigCalendarioTodoist"
                                                styleClass="button-primary"/>
                                        <Button text="Restablecer valores"
                                                onAction="#onRestablecerConfigTodoist"
                                                styleClass="button-secondary"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </content>
                    </ScrollPane>

                  
                    <!-- 3: Contactos -->
                    <ScrollPane fitToWidth="true"
                                hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED"
                                styleClass="config-scroll"
                                maxHeight="Infinity"
                                maxWidth="Infinity"
                                visible="false"
                                managed="false">
                        <content>
                            <VBox spacing="18" styleClass="config-tab-inner">
                                <padding>
                                    <Insets top="20" right="24" bottom="32" left="20"/>
                                </padding>

                                <Label text="Contactos" styleClass="config-page-heading"/>

                                <!-- Gestión de Contactos -->
                                <VBox styleClass="config-section-box" spacing="12">
                                    <Label text="Importación y exportación" styleClass="config-section-kicker"/>
                                    <Label text="Importa contactos desde archivos vCard o CSV, o exporta tus contactos actuales."
                                           styleClass="label-secondary"
                                           wrapText="true"/>

                                    <Separator styleClass="config-sep"/>

                                    <GridPane hgap="14" vgap="12" styleClass="config-form-grid">
                                        <columnConstraints>
                                            <ColumnConstraints halignment="RIGHT" minWidth="148" prefWidth="156"/>
                                            <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                                        </columnConstraints>

                                        <Label text="Importar contactos"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="0"/>
                                        <HBox spacing="8" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                            <TextField fx:id="txtImportarContactosPath"
                                                      promptText="/ruta/a/contactos.vcf"
                                                      HBox.hgrow="ALWAYS"/>
                                            <Button fx:id="btnSeleccionarImportarContactos"
                                                    text="Seleccionar"
                                                    onAction="#onSeleccionarImportarContactos"/>
                                            <Button fx:id="btnImportarContactos"
                                                    text="Importar"
                                                    onAction="#onImportarContactos"/>
                                        </HBox>

                                        <Label text="Exportar contactos"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="1"
                                               GridPane.columnIndex="0"/>
                                        <HBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                            <TextField fx:id="txtExportarContactosPath"
                                                      promptText="/ruta/para/exportar.vcf"
                                                      HBox.hgrow="ALWAYS"/>
                                            <Button fx:id="btnSeleccionarExportarContactos"
                                                    text="Seleccionar"
                                                    onAction="#onSeleccionarExportarContactos"/>
                                            <Button fx:id="btnExportarContactos"
                                                    text="Exportar"
                                                    onAction="#onExportarContactos"/>
                                        </HBox>
                                    </GridPane>
                                </VBox>

                                <!-- Remitentes Confiables -->
                                <VBox styleClass="config-section-box" spacing="12">
                                    <Label text="Remitentes confiables" styleClass="config-section-kicker"/>
                                    <Label text="Gestiona la lista de remitentes que siempre serán marcados como legítimos."
                                           styleClass="label-secondary"
                                           wrapText="true"/>

                                    <Separator styleClass="config-sep"/>

                                    <HBox spacing="8">
                                        <TextField fx:id="txtNuevoRemitenteConfiable"
                                                  promptText="email@ejemplo.com"
                                                  HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="btnAgregarRemitenteConfiable"
                                                text="Agregar"
                                                onAction="#onAgregarRemitenteConfiable"/>
                                    </HBox>

                                    <ListView fx:id="listaRemitentesConfiables"
                                              prefHeight="150"
                                              VBox.vgrow="ALWAYS"/>

                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <Button fx:id="btnEliminarRemitenteConfiable"
                                                text="Eliminar seleccionado"
                                                onAction="#onEliminarRemitenteConfiable"
                                                styleClass="button-secondary"/>
                                        <Button fx:id="btnCargarRemitentesConfiables"
                                                text="Recargar lista"
                                                onAction="#onCargarRemitentesConfiables"
                                                styleClass="button-secondary"/>
                                    </HBox>

                                    <Label fx:id="lblContactosEstado"
                                           styleClass="label-secondary"
                                           wrapText="true"/>
                                </VBox>

                                <!-- Sincronización de Contactos -->
                                <VBox styleClass="config-section-box" spacing="12">
                                    <Label text="Sincronización" styleClass="config-section-kicker"/>
                                    <Label text="Configura la sincronización de contactos con el servidor de correo."
                                           styleClass="label-secondary"
                                           wrapText="true"/>

                                    <Separator styleClass="config-sep"/>

                                    <GridPane hgap="14" vgap="12" styleClass="config-form-grid">
                                        <columnConstraints>
                                            <ColumnConstraints halignment="RIGHT" minWidth="148" prefWidth="156"/>
                                            <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                                        </columnConstraints>

                                        <Label text="Sincronizar automáticamente"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="0"/>
                                        <CheckBox fx:id="chkSyncContactosAuto"
                                                  GridPane.rowIndex="0"
                                                  GridPane.columnIndex="1"/>

                                        <Label text="Intervalo de sincronización"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="1"
                                               GridPane.columnIndex="0"/>
                                        <HBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                            <Spinner fx:id="spinnerSyncContactosInterval"
                                                      prefWidth="120"
                                                      min="15"
                                                      max="1440"
                                                      amountToStepBy="15"
                                                      initialValue="60"/>
                                            <Label text="minutos" styleClass="label-secondary"/>
                                        </HBox>
                                    </GridPane>

                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <Button text="Guardar configuración"
                                                onAction="#onGuardarConfigContactos"
                                                styleClass="button-primary"/>
                                        <Button text="Sincronizar ahora"
                                                onAction="#onSincronizarContactosAhora"
                                                styleClass="button-secondary"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </content>
                    </ScrollPane>

                    <!-- 4: IA -->
                    <ScrollPane fitToWidth="true"
                                hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED"
                                styleClass="config-scroll"
                                maxHeight="Infinity"
                                maxWidth="Infinity"
                                visible="false"
                                managed="false">
                        <content>
                            <VBox spacing="18" styleClass="config-tab-inner">
                                <padding>
                                    <Insets top="20" right="24" bottom="32" left="20"/>
                                </padding>

                                <Label text="Inteligencia artificial" styleClass="config-page-heading"/>

                                <VBox styleClass="config-section-box" spacing="12">
                                    <Label text="Motor local" styleClass="config-section-kicker"/>
                                    <Label text="Configura la URL y el modelo para usar un servicio local como Ollama."
                                           styleClass="label-secondary"
                                           wrapText="true"/>

                                    <GridPane hgap="14" vgap="12" styleClass="config-form-grid">
                                        <columnConstraints>
                                            <ColumnConstraints halignment="RIGHT" minWidth="148" prefWidth="156"/>
                                            <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                                        </columnConstraints>

                                        <Label text="URL"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtOllamaUrl"
                                                   promptText="http://localhost:11434"
                                                   GridPane.rowIndex="0"
                                                   GridPane.columnIndex="1"/>

                                        <Label text="Modelo"
                                               styleClass="config-field-label"
                                               GridPane.rowIndex="1"
                                               GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtOllamaModelo"
                                                   promptText="llama3"
                                                   GridPane.rowIndex="1"
                                                   GridPane.columnIndex="1"/>
                                    </GridPane>

                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Button text="Guardar configuración"
                                                onAction="#onGuardarConfigIA"
                                                styleClass="config-primary-btn"/>
                                        <Button text="Probar conexión"
                                                onAction="#onTestOllama"
                                                styleClass="config-secondary-btn"/>
                                    </HBox>

                                    <Label fx:id="lblTestIA"
                                           text=""
                                           styleClass="status-label"
                                           wrapText="true"/>
                                </VBox>
                            </VBox>
                        </content>
                    </ScrollPane>

                </StackPane>
            </items>
        </SplitPane>
    </center>

    <bottom>
    <VBox spacing="0" styleClass="config-footer-wrap">
        <Separator/>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="14" right="22" bottom="18" left="22"/>
            </padding>

            <Button fx:id="btnResetOpciones"
                    text="Resetear opciones"
                    onAction="#onResetOpcionesClicked"
                    styleClass="config-secondary-btn"
                    visible="false"
                    managed="false"/>

            <Button text="Guardar"
                    fx:id="saveButton"
                    defaultButton="true"
                    styleClass="config-primary-btn"
                    onAction="#onSaveClicked"/>
        </HBox>
    </VBox>
</bottom>

</BorderPane>